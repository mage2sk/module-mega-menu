function renderMobileSlide() {
  var html = '<div class="relative bg-white dark:bg-gray-800 shadow-lg rounded-xl overflow-hidden" style="height: 500px;">';

  // Main menu
  html += '<nav class="mobile-slide-main absolute inset-0 overflow-y-auto p-2">';
  html += '<ul class="space-y-1">';

  items.filter(it => it.level === 0 && it.is_active).forEach((it, idx) => {
    var iconHtml = it.icon ? renderIconPreview(it.icon, it.icon_library) : '';
    var children = items.filter(child => child.parent_id === (it.temp_id || it.item_id) && child.is_active);
    var hasChildren = children.length > 0;
    var slideId = 'slide-' + idx;

    html += '<li class="border-b border-gray-200 dark:border-gray-700 last:border-0">';

    // Treat items with children OR CMS blocks as having a slide submenu
    if (hasChildren || (it.item_type === 'cms_block' && it.cms_block_id)) {
      html += `<a href="#" class="mobile-slide-open flex items-center justify-between px-4 py-3 font-semibold text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all" data-target="${slideId}">
        <span class="flex items-center gap-2">${iconHtml ? iconHtml + ' ' : ''}${it.title}</span>
        <span class="text-gray-400">▶</span>
      </a>`;
    } else {
      var hasUrl = it.url && it.url.trim() !== '';
      var tagName = 'a';
      var hrefAttr = `href="${it.url || '#'}" target="${it.target || '_self'}"`;

      html += `<${tagName} ${hrefAttr} class="flex items-center justify-between px-4 py-3 font-semibold text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all">
        <span class="flex items-center gap-2">${iconHtml ? iconHtml + ' ' : ''}${it.title}</span>
      </${tagName}>`;
    }

    html += '</li>';
  });

  html += '</ul></nav>';

  // Generate all submenus
  items.filter(it => it.level === 0 && it.is_active).forEach((it, idx) => {
    var children = items.filter(child => child.parent_id === (it.temp_id || it.item_id) && child.is_active);
    var hasChildren = children.length > 0;
    var hasCmsBlock = it.item_type === 'cms_block' && it.cms_block_id;
    var slideId = 'slide-' + idx;

    // Show submenu if it has children OR is a CMS block
    if (hasChildren || hasCmsBlock) {
      html += `<div id="${slideId}" class="mobile-slide-submenu bg-white dark:bg-gray-800 p-2">`;
      html += `<div class="mb-2 pb-2 border-b border-gray-200 dark:border-gray-700">`;
      html += `<button class="mobile-slide-back flex items-center gap-2 px-4 py-2 text-indigo-600 dark:text-indigo-400 font-semibold text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all w-full">
        <span>◀ Back</span>
      </button>`;
      html += `<div class="px-4 py-2 font-bold text-lg">${it.title}</div>`;

      // Show CMS block content if it's a CMS block type
      if (hasCmsBlock) {
        html += '<div class="mb-3 pb-3 border-b border-gray-200 dark:border-gray-700 px-4 py-2">';
        html += `<div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${it.cms_block_id})</div>`;
        html += '<div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>';
        html += '</div>';
      }

      html += '</div>';
      if (hasChildren) {
        html += '<ul class="space-y-1">';
        html += renderMobileSlideChildren(children, idx);
        html += '</ul>';
      }
      html += '</div>';
    }
  });

  html += '</div>';
  return html;
}

function renderMobileSlideChildren(children, parentIdx) {
  var html = '';

  children.forEach((child, idx) => {
    var childIcon = child.icon ? renderIconPreview(child.icon, child.icon_library) : '';
    var grandchildren = items.filter(gc => gc.parent_id === (child.temp_id || child.item_id) && gc.is_active);
    var hasGrandchildren = grandchildren.length > 0;
    var slideId = 'slide-' + parentIdx + '-' + idx;

    html += '<li class="border-b border-gray-200 dark:border-gray-700 last:border-0">';

    var hasCmsBlock = child.item_type === 'cms_block' && child.cms_block_id;

    // Treat items with grandchildren OR CMS blocks as having a slide submenu
    if (hasGrandchildren || hasCmsBlock) {
      html += `<a href="#" class="mobile-slide-open flex items-center justify-between px-4 py-2.5 text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all" data-target="${slideId}">
        <span class="flex items-center gap-2">${childIcon ? childIcon + ' ' : ''}${child.title}</span>
        <span class="text-gray-400">▶</span>
      </a>`;
    } else {
      var hasUrl = child.url && child.url.trim() !== '';
      var tagName = 'a';
      var hrefAttr = `href="${child.url || '#'}" target="${child.target || '_self'}"`;

      html += `<${tagName} ${hrefAttr} class="flex items-center justify-between px-4 py-2.5 text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all">
        <span class="flex items-center gap-2">${childIcon ? childIcon + ' ' : ''}${child.title}</span>
      </${tagName}>`;
    }

    html += '</li>';

    // Generate nested submenu
    if (hasGrandchildren || hasCmsBlock) {
      html += `<div id="${slideId}" class="mobile-slide-submenu bg-white dark:bg-gray-800 p-2">`;
      html += `<div class="mb-2 pb-2 border-b border-gray-200 dark:border-gray-700">`;
      html += `<button class="mobile-slide-back flex items-center gap-2 px-4 py-2 text-indigo-600 dark:text-indigo-400 font-semibold text-base hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-all w-full">
        <span>◀ Back</span>
      </button>`;
      html += `<div class="px-4 py-2 font-bold text-lg">${child.title}</div>`;

      // Show CMS block content if it's a CMS block type
      if (hasCmsBlock) {
        html += '<div class="mb-3 pb-3 border-b border-gray-200 dark:border-gray-700 px-4 py-2">';
        html += `<div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${child.cms_block_id})</div>`;
        html += '<div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>';
        html += '</div>';
      }

      html += '</div>';
      if (hasGrandchildren) {
        html += '<ul class="space-y-1">';
        html += renderMobileSlideChildren(grandchildren, slideId);
        html += '</ul>';
      }
      html += '</div>';
    }
  });

  return html;
}

function renderPreviewChildren(children, mode, parent) {
  var html = '';
  children.forEach(child => {
    var childIcon = child.icon ? renderIconPreview(child.icon, child.icon_library) : '';
    var grandchildren = items.filter(gc => gc.parent_id === (child.temp_id || child.item_id) && gc.is_active);
    var hasGrandchildren = grandchildren.length > 0;

    var hoverClass = 'hover-' + (child.hover_effect || 'fade');
    var bgColor = child.background_color || '';
    var textColor = child.text_color || '';
    var itemStyle = '';
    if (bgColor) itemStyle += `background-color: ${bgColor}; `;
    if (textColor) itemStyle += `color: ${textColor};`;

    // Use span for CMS blocks without URL, a tag for items with URL
    var hasUrl = child.url && child.url.trim() !== '';
    var tagName = (child.item_type === 'cms_block' && !hasUrl) ? 'span' : 'a';
    var hrefAttr = tagName === 'a' ? `href="${child.url || '#'}" target="${child.target || '_self'}"` : '';

    html += `<li class="relative ${hasGrandchildren || child.item_type === 'cms_block' ? 'group' : ''}">
      <${tagName} ${hrefAttr} class="flex items-center justify-between px-4 py-2.5 rounded-lg ${hoverClass} transition-all text-base ${child.css_class || ''} cursor-pointer" style="${itemStyle}">
        <span class="flex items-center gap-2">
          ${childIcon ? childIcon + ' ' : ''}${child.title}
        </span>
        ${hasGrandchildren || child.item_type === 'cms_block' ? `<span class="text-gray-400">▶</span>` : ''}
      </${tagName}>`;

    if (hasGrandchildren) {
      var submenuCols = child.submenu_columns || 1;
      var gridClass = submenuCols > 1 ? `grid grid-cols-${submenuCols} gap-4` : '';
      var minWidth = submenuCols > 1 ? `min-w-[${Math.min(submenuCols * 220, 1000)}px]` : 'min-w-[220px]';

      html += `<ul class="preview-dropdown-nested absolute left-full top-0 ml-2 bg-white dark:bg-gray-800 shadow-2xl rounded-xl p-3 ${minWidth} border-2 border-gray-200 dark:border-gray-700 ${gridClass}">`;
      html += renderPreviewChildren(grandchildren, mode, child);
      html += '</ul>';
    } else if (child.item_type === 'cms_block' && child.cms_block_id) {
      // Show CMS block content placeholder in dropdown
      html += `<div class="preview-dropdown-nested absolute left-full top-0 ml-2 bg-white dark:bg-gray-800 shadow-2xl rounded-xl p-4 min-w-[300px] max-w-[500px] border-2 border-gray-200 dark:border-gray-700">
        <div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${child.cms_block_id})</div>
        <div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>
      </div>`;
    }

    html += '</li>';
  });
  return html;
}

// SAVE
async function save() {
  var t = document.getElementById('title').value.trim();
  var id = document.getElementById('identifier').value.trim();

  if (!t) {
    await showAlert('Menu Title is required!', '❌', 'Error');
    document.getElementById('title').focus();
    return;
  }

  if (!id) {
    await showAlert('Menu Identifier is required!', '❌', 'Error');
    document.getElementById('identifier').focus();
    return;
  }

  if (!/^[a-z0-9_]+$/.test(id)) {
    await showAlert('Identifier must contain only lowercase letters, numbers, and underscores!', '❌', 'Error');
    document.getElementById('identifier').focus();
    return;
  }

  // Validate and clean up items
  var hasErrors = false;
  var invalidChildren = [];

  // Remove children from CMS Block and Custom HTML items
  items.forEach((it, i) => {
    var itId = it.temp_id || it.item_id;

    // Find if this item has a parent that's cms_block or custom_html
    var parent = items.find(p => (p.temp_id || p.item_id) === it.parent_id);
    if (parent && (parent.item_type === 'cms_block' || parent.item_type === 'custom_html')) {
      invalidChildren.push(i);
      it.parent_id = null;
      it.level = 0;
    }
  });

  if (invalidChildren.length > 0) {
    await showAlert('Warning: ' + invalidChildren.length + ' item(s) were moved to top level because their parent was a CMS Block or Custom HTML item (which cannot have children).', '⚠️', 'Warning');
  }

  // Comprehensive validation for items
  for (let i = 0; i < items.length; i++) {
    var it = items[i];
    var itemNum = i + 1;

    // Title validation
    if (!it.title || !it.title.trim()) {
      await showAlert('Item #' + itemNum + ' is missing a title!\n\nPlease provide a title for this menu item.', '❌', 'Validation Error');
      return;
    }

    // Title length validation
    if (it.title.trim().length > 255) {
      await showAlert('Item #' + itemNum + ' (' + it.title.substring(0, 50) + '...) has a title that is too long!\n\nMaximum 255 characters allowed.', '❌', 'Validation Error');
      return;
    }

    // Item type validation
    if (!it.item_type) {
      await showAlert('Item #' + itemNum + ' (' + it.title + ') is missing an item type!\n\nPlease select a type (Category, CMS Page, Link, etc.).', '❌', 'Validation Error');
      return;
    }

    // Type-specific validation
    switch (it.item_type) {
      case 'category':
        if (!it.category_id) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a Category type but no category is selected!\n\nPlease click "Select Category" to choose a category.', '❌', 'Validation Error');
          return;
        }
        if (!it.url || !it.url.trim()) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is missing a URL!\n\nPlease select a category using the "Select Category" button.', '❌', 'Validation Error');
          return;
        }
        break;

      case 'cms_page':
        if (!it.cms_page_id) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a CMS Page type but no page is selected!\n\nPlease click "Select Page" to choose a CMS page.', '❌', 'Validation Error');
          return;
        }
        if (!it.url || !it.url.trim()) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is missing a URL!\n\nPlease select a CMS page using the "Select Page" button.', '❌', 'Validation Error');
          return;
        }
        break;

      case 'link':
        if (!it.url || !it.url.trim()) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a Link type but no URL is provided!\n\nPlease enter a URL for this link.', '❌', 'Validation Error');
          return;
        }
        // URL format validation for links
        var urlPattern = /^(https?:\/\/|\/|#)/i;
        if (!urlPattern.test(it.url.trim())) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') has an invalid URL format!\n\nURL must start with http://, https://, / or #\n\nCurrent URL: ' + it.url, '❌', 'Validation Error');
          return;
        }
        break;

      case 'custom':
        if (!it.url || !it.url.trim()) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a Custom URL type but no URL is provided!\n\nPlease enter a custom URL.', '❌', 'Validation Error');
          return;
        }
        break;

      case 'cms_block':
        if (!it.cms_block_id) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a CMS Block type but no block is selected!\n\nPlease click "Select Block" to choose a CMS block.', '❌', 'Validation Error');
          return;
        }
        break;

      case 'custom_html':
        if (!it.custom_html || !it.custom_html.trim()) {
          await showAlert('Item #' + itemNum + ' (' + it.title + ') is a Custom HTML type but no HTML content is provided!\n\nPlease enter HTML content.', '❌', 'Validation Error');
          return;
        }
        break;
    }

    // Level validation
    if (it.level < 0 || it.level > 5) {
      await showAlert('Item #' + itemNum + ' (' + it.title + ') has an invalid level!\n\nLevel must be between 0 and 5. Current level: ' + it.level, '❌', 'Validation Error');
      return;
    }

    // CSS class validation (if provided)
    if (it.css_class && it.css_class.trim()) {
      var cssPattern = /^[a-zA-Z0-9_\-\s]+$/;
      if (!cssPattern.test(it.css_class.trim())) {
        await showAlert('Item #' + itemNum + ' (' + it.title + ') has an invalid CSS class!\n\nCSS class can only contain letters, numbers, hyphens, underscores, and spaces.\n\nCurrent: ' + it.css_class, '❌', 'Validation Error');
        return;
      }
    }
  }

  // Check for duplicate identifiers in items (temp_id vs item_id conflicts)
  var usedIds = new Set();
  for (let i = 0; i < items.length; i++) {
    var itemId = items[i].temp_id || items[i].item_id;
    if (usedIds.has(itemId)) {
      await showAlert('Duplicate item ID detected!\n\nThis is a system error. Please refresh the page and try again.', '❌', 'System Error');
      return;
    }
    usedIds.add(itemId);
  }

  // Validate parent-child relationships
  for (let i = 0; i < items.length; i++) {
    var it = items[i];
    if (it.parent_id) {
      var parentExists = items.find(p => (p.temp_id || p.item_id) === it.parent_id);
      if (!parentExists) {
        await showAlert('Item #' + (i + 1) + ' (' + it.title + ') references a parent that does not exist!\n\nThis is a system error. The item will be moved to top level.', '⚠️', 'Warning');
        it.parent_id = null;
        it.level = 0;
      }
    }
  }

  var btn = document.getElementById('saveBtn');
  var txt = document.getElementById('saveTxt');
  btn.disabled = true;
  btn.classList.add('opacity-50', 'cursor-not-allowed');
  txt.textContent = '⏳ Saving...';

  fetch('<?= $block->escapeUrl($block->getSaveUrl()) ?>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      menu: {
        menu_id: md.menu_id || null,
        title: t,
        identifier: id,
        is_active: document.getElementById('active').checked ? 1 : 0,
        css_class: document.getElementById('css').value,
        sort_order: document.getElementById('sort').value,
        description: document.getElementById('desc').value,
        custom_css: document.getElementById('customcss').value
      },
      items: items,
      form_key: document.querySelector('input[name="form_key"]').value
    })
  })
  .then(r => r.json())
  .then(async d => {
    if (d.success) {
      location.href = '<?= $block->escapeUrl($block->getListUrl()) ?>';
    } else {
      await showAlert('Error: ' + (d.message || 'Failed to save menu'), '❌', 'Error');
      btn.disabled = false;
      btn.classList.remove('opacity-50', 'cursor-not-allowed');
      txt.textContent = '💾 Save Menu';
    }
  })
  .catch(async e => {
    await showAlert('Error saving menu: ' + e.message, '❌', 'Error');
    btn.disabled = false;
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
    txt.textContent = '💾 Save Menu';
  });
}

