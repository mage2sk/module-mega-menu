      <input type="text" placeholder="URL" value="${it.url || ''}" readonly
             class="w-full px-4 py-3 text-base border-2 border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-800 dark:text-white bg-gray-100">`;

    case 'cms_page':
