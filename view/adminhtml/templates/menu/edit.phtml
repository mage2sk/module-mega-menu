// Preview handler — called by the admin Preview button (panthPreviewMenu)
window.panthPreviewMenu = function() {
    var baseUrl = window.location.origin + '/';
    var ts = Date.now();
    var previewUrl = baseUrl + 'panth_menu/preview/index?_t=' + ts;

    // Collect all current form data
    var formData = {
        items_json: JSON.stringify(items),
        css_class: document.getElementById('css') ? document.getElementById('css').value : '',
        custom_css: document.getElementById('customcss') ? document.getElementById('customcss').value : '',
        container_bg_color: '',
        container_padding: '',
        container_margin: '',
        item_gap: '',
        container_max_width: '',
        container_border: '',
        container_border_radius: '',
        container_box_shadow: ''
    };

    // Try to read container styling fields from UI component
    try {
        var fields = document.querySelectorAll('[name="container_bg_color"],[name="container_padding"],[name="container_margin"],[name="item_gap"],[name="container_max_width"],[name="container_border"],[name="container_border_radius"],[name="container_box_shadow"]');
        fields.forEach(function(f) { if (f.name && f.value) formData[f.name] = f.value; });
    } catch(e) {}

    console.log('[Preview] Posting', Object.keys(formData).length, 'fields, items:', items.length);

    // Create hidden form and POST to iframe or new tab
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = previewUrl;
    form.target = 'megamenu_preview_' + ts;
    form.style.display = 'none';

    for (var key in formData) {
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = formData[key];
        form.appendChild(input);
    }

    document.body.appendChild(form);
    form.submit();
    setTimeout(function() { form.remove(); }, 1000);
};

