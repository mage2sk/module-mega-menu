function renderTypeOptions(currentType, level) {
  var options = '';
  var types = level > 0
    ? ['category', 'cms_page', 'link', 'custom', 'cms_block', 'custom_html']
    : ['category', 'cms_page', 'link', 'custom', 'cms_block'];

  var labels = {
    category: '📁 Category',
    cms_page: '📄 CMS Page',
    link: '🔗 Link',
    custom: '⚙️ Custom URL',
    cms_block: '📦 CMS Block (Dropdown)',
    custom_html: '✏️ Custom HTML'
  };

  types.forEach(type => {
    options += `<option value="${type}"${currentType === type ? ' selected' : ''}>${labels[type]}</option>`;
  });

  return options;
}

