}

function selectIcon(icon) {
  items[iconIdx].icon = icon;
  items[iconIdx].icon_library = iconLibrary;
  closeIconPicker();
  render();
}

// SAVE & PREVIEW - saves current form data via AJAX, then opens frontend preview in new tab
async function saveAndPreview() {
  var md = <?= /* @noEscape */ json_encode($menuData, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
  var t = document.getElementById('title').value.trim();
  var id = document.getElementById('identifier').value.trim();

  console.log('[Preview] Starting saveAndPreview...');
  console.log('[Preview] menu_id:', md.menu_id, 'title:', t, 'identifier:', id);
  console.log('[Preview] items count:', items.length);

  if (!t) { await showAlert('Please enter a menu title!', '❌', 'Error'); return; }
  if (!id) { await showAlert('Please enter an identifier!', '❌', 'Error'); return; }

  var btn = document.getElementById('previewBtn');
  var txt = document.getElementById('previewBtnTxt');
  btn.disabled = true;
  txt.textContent = '⏳ Saving...';

  try {
    // Step 1: Save via FormData
    var saveUrl = '<?= $block->escapeUrl($block->getSaveUrl()) ?>';
    console.log('[Preview] Step 1: Saving to', saveUrl);

    var formData = new FormData();
    formData.append('form_key', document.querySelector('input[name="form_key"]').value);
    formData.append('menu_id', md.menu_id || '');
    formData.append('title', t);
    formData.append('identifier', id);
    formData.append('is_active', document.getElementById('active').checked ? '1' : '0');
    formData.append('css_class', document.getElementById('css').value);
    formData.append('sort_order', document.getElementById('sort').value);
    formData.append('description', document.getElementById('desc').value);
    formData.append('custom_css', document.getElementById('customcss').value);
    formData.append('items_json', JSON.stringify(items));
    formData.append('back', '1');

    // Log FormData entries
    for (var pair of formData.entries()) {
      if (pair[0] === 'items_json') {
        console.log('[Preview] FormData:', pair[0], '(length:', pair[1].length, ')');
      } else {
        console.log('[Preview] FormData:', pair[0], '=', pair[1]);
      }
    }

    var saveResponse = await fetch(saveUrl, {
      method: 'POST',
      body: formData,
      redirect: 'follow'
    });

    console.log('[Preview] Save response status:', saveResponse.status, saveResponse.statusText);
    console.log('[Preview] Save response URL:', saveResponse.url);
    console.log('[Preview] Save response ok:', saveResponse.ok);

    // The save controller returns a redirect to the edit page (302->200)
    // After fetch follows the redirect, we get a 200 HTML page
    // Check if the final URL contains 'edit' (success) or error indicators
    var saveBody = await saveResponse.text();
    var saveSuccess = saveResponse.ok;
    var hasError = saveBody.includes('error-msg') || saveBody.includes('Something went wrong');

    console.log('[Preview] Save body length:', saveBody.length);
    console.log('[Preview] Has error message:', hasError);
    console.log('[Preview] Save considered successful:', saveSuccess && !hasError);

    if (!saveSuccess || hasError) {
      // Try to extract error message
      var errorMatch = saveBody.match(/error-msg[^>]*>([^<]+)/);
      var errorMsg = errorMatch ? errorMatch[1] : 'Unknown error';
      console.error('[Preview] Save failed:', errorMsg);
      await showAlert('Save failed: ' + errorMsg, '❌', 'Error');
      btn.disabled = false;
      txt.textContent = '👁️ Preview';
      return;
    }

    console.log('[Preview] Step 1 DONE - Save successful');

    var menuId = md.menu_id;
    txt.textContent = '⏳ Opening preview...';

    // Step 2: Just open the frontend URL directly (menu is saved, will load from DB)
    // Skip the token mechanism for now — just open the regular preview page
    var previewUrl = window.location.origin + '/panth_menu/preview/index?menu_id=' + encodeURIComponent(menuId);
    console.log('[Preview] Step 2: Opening preview URL:', previewUrl);

    window.open(previewUrl, '_blank');

    console.log('[Preview] Preview opened successfully');
    btn.disabled = false;
    txt.textContent = '👁️ Preview';

  } catch (e) {
    await showAlert('Error: ' + e.message, '❌', 'Error');
    btn.disabled = false;
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
    txt.textContent = '👁️ Preview';
  }
}

// IN-PAGE PREVIEW (client-side preview panel)
function togglePreview() {
  var panel = document.getElementById('previewPanel');
  if (panel.classList.contains('hidden')) {
    panel.classList.remove('hidden');
    panel.classList.add('flex');
    renderPreview();
  } else {
    panel.classList.add('hidden');
    panel.classList.remove('flex');
  }
}

function setPreviewMode(mode) {
  var content = document.getElementById('previewContent');
  content.className = 'preview-' + mode;

  // Show/hide mobile layout selector
  var mobileLayoutSelector = document.getElementById('mobileLayoutSelector');
  if (mode === 'mobile') {
    mobileLayoutSelector.classList.remove('hidden');
    mobileLayoutSelector.classList.add('flex');
  } else {
    mobileLayoutSelector.classList.add('hidden');
    mobileLayoutSelector.classList.remove('flex');
  }

  // Update button states
  document.querySelectorAll('#previewPanel button').forEach(btn => {
    if (btn.textContent.includes('Desktop')) {
      btn.className = mode === 'desktop' ? 'px-4 py-2 bg-indigo-500 text-white rounded-lg font-semibold' : 'px-4 py-2 bg-gray-500 text-white rounded-lg font-semibold';
    } else if (btn.textContent.includes('Tablet')) {
      btn.className = mode === 'tablet' ? 'px-4 py-2 bg-indigo-500 text-white rounded-lg font-semibold' : 'px-4 py-2 bg-gray-500 text-white rounded-lg font-semibold';
    } else if (btn.textContent.includes('Mobile') && !btn.textContent.includes('Tablet')) {
      btn.className = mode === 'mobile' ? 'px-4 py-2 bg-indigo-500 text-white rounded-lg font-semibold' : 'px-4 py-2 bg-gray-500 text-white rounded-lg font-semibold';
    }
  });

  renderPreview();
}

function setMobileLayout(layout) {
  var content = document.getElementById('previewContent');
  content.setAttribute('data-mobile-layout', layout);

  // Update layout button states
  var btnAccordion = document.getElementById('btnAccordion');
  var btnSlide = document.getElementById('btnSlide');

  if (layout === 'accordion') {
    btnAccordion.className = 'px-3 py-1 bg-indigo-500 text-white rounded-lg text-sm font-semibold';
    btnSlide.className = 'px-3 py-1 bg-gray-500 text-white rounded-lg text-sm font-semibold';
  } else {
    btnAccordion.className = 'px-3 py-1 bg-gray-500 text-white rounded-lg text-sm font-semibold';
    btnSlide.className = 'px-3 py-1 bg-indigo-500 text-white rounded-lg text-sm font-semibold';
  }

  renderPreview();
}

function renderPreview() {
  var content = document.getElementById('previewContent');
  var mode = content.className.replace('preview-', '');
  var mobileLayout = content.getAttribute('data-mobile-layout') || 'accordion';

  var html = '<style>';
  html += '.preview-dropdown { opacity: 0; visibility: hidden; transform: translateY(-10px); transition: opacity 0.3s, visibility 0.3s, transform 0.3s; max-height: none; overflow: visible; z-index: 1000; position: absolute; left: 0; top: 100%; }';
  html += '.preview-dropdown-nested { opacity: 0; visibility: hidden; transform: translateX(-10px); transition: opacity 0.3s, visibility 0.3s, transform 0.3s; max-height: none; overflow: visible; z-index: 1200; position: absolute; left: 100%; top: 0; margin-left: 0.5rem; background: white; border: 2px solid #e5e7eb; border-radius: 0.75rem; padding: 0.75rem; min-width: 220px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }';
  html += '.group:hover > .preview-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }';
  html += '.group:hover > .preview-dropdown-nested { opacity: 1; visibility: visible; transform: translateX(0); }';
  html += '.preview-dropdown .group:hover > .preview-dropdown-nested { z-index: 1300; }';
  html += '.hover-fade:hover { opacity: 0.7 !important; transition: opacity 0.3s; }';
  html += '.hover-slide:hover { transform: translateY(-4px) !important; transition: transform 0.3s; }';
  html += '.hover-zoom:hover { transform: scale(1.05) !important; transition: transform 0.3s; }';
  html += '.hover-underline:hover { text-decoration: underline !important; text-underline-offset: 4px; }';
  html += '.hover-glow:hover { box-shadow: 0 0 20px rgba(99, 102, 241, 0.5) !important; transition: box-shadow 0.3s; }';

  // Mobile accordion styles
  if (mode === 'mobile' && mobileLayout === 'accordion') {
    html += '.mobile-accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }';
    html += '.mobile-accordion-content.active { max-height: 2000px; transition: max-height 0.5s ease-in; }';
    html += '.mobile-accordion-btn { transition: transform 0.3s; }';
    html += '.mobile-accordion-btn.active { transform: rotate(180deg); }';
  }

  // Mobile slide styles
  if (mode === 'mobile' && mobileLayout === 'slide') {
    html += '.mobile-slide-main { transition: transform 0.3s ease-in-out; }';
    html += '.mobile-slide-main.slide-out { transform: translateX(-100%); }';
    html += '.mobile-slide-submenu { position: absolute; top: 0; left: 100%; width: 100%; height: 100%; transition: transform 0.3s ease-in-out; transform: translateX(0); overflow-y: auto; }';
    html += '.mobile-slide-submenu.slide-in { transform: translateX(-100%); }';
  }

  // Add responsive container styles
  if (mode === 'desktop') {
    html += '.megamenu-container { max-width: 100%; }';
  } else if (mode === 'tablet') {
    html += '.megamenu-container { max-width: 768px; margin: 0 auto; }';
  } else if (mode === 'mobile') {
    html += '.megamenu-container { max-width: 375px; margin: 0 auto; position: relative; overflow: hidden; }';
  }

  // Add custom CSS from menu settings
  var customCss = document.getElementById('customcss').value;
  if (customCss) {
    html += customCss;
  }

  html += '</style>';

  // Get menu CSS class from settings
  var menuCssClass = document.getElementById('css').value || '';
  html += '<div class="megamenu-container ' + menuCssClass + '">';

  if (mode === 'mobile') {
    if (mobileLayout === 'accordion') {
      html += renderMobileAccordion();
    } else {
      html += renderMobileSlide();
    }
  } else {
    html += renderDesktopTabletMenu(mode);
  }

  html += '</div>';
  content.innerHTML = html;

  // Attach event listeners for mobile accordion
  if (mode === 'mobile' && mobileLayout === 'accordion') {
    document.querySelectorAll('.mobile-accordion-toggle').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var target = this.getAttribute('data-target');
        var contentEl = document.getElementById(target);
        var btnIcon = this.querySelector('.mobile-accordion-btn');

        if (contentEl.classList.contains('active')) {
          contentEl.classList.remove('active');
          btnIcon.classList.remove('active');
        } else {
          contentEl.classList.add('active');
          btnIcon.classList.add('active');
        }
      });
    });
  }

  // Attach event listeners for mobile slide
  if (mode === 'mobile' && mobileLayout === 'slide') {
    var slideStack = [];

    document.querySelectorAll('.mobile-slide-open').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var target = this.getAttribute('data-target');
        var submenu = document.getElementById(target);

        slideStack.push(target);
        submenu.classList.add('slide-in');
        document.querySelector('.mobile-slide-main').classList.add('slide-out');
      });
    });

    document.querySelectorAll('.mobile-slide-back').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        if (slideStack.length > 0) {
          var target = slideStack.pop();
          var submenu = document.getElementById(target);
          submenu.classList.remove('slide-in');
          if (slideStack.length === 0) {
            document.querySelector('.mobile-slide-main').classList.remove('slide-out');
          }
        }
      });
    });
  }
}

function renderDesktopTabletMenu(mode) {
  var html = '<nav class="bg-white dark:bg-gray-800 shadow-lg rounded-xl p-4"><ul class="flex flex-wrap gap-4">';

  items.filter(it => it.level === 0 && it.is_active).forEach(it => {
    var hoverClass = 'hover-' + (it.hover_effect || 'fade');
    var iconHtml = it.icon ? renderIconPreview(it.icon, it.icon_library) : '';
    var bgColor = it.background_color || '';
    var textColor = it.text_color || '';
    var itemStyle = '';
    if (bgColor) itemStyle += `background-color: ${bgColor}; `;
    if (textColor) itemStyle += `color: ${textColor};`;

    // Use span for CMS blocks without URL, a tag for items with URL
    var hasUrl = it.url && it.url.trim() !== '';
    var tagName = (it.item_type === 'cms_block' && !hasUrl) ? 'span' : 'a';
    var hrefAttr = tagName === 'a' ? `href="${it.url || '#'}" target="${it.target || '_self'}"` : '';

    html += `<li class="relative group">
      <${tagName} ${hrefAttr} class="flex items-center gap-2 px-4 py-3 rounded-lg ${hoverClass} ${it.css_class || ''} font-semibold text-base cursor-pointer" style="${itemStyle}">
        <span class="flex items-center gap-2">${iconHtml ? iconHtml + ' ' : ''}${it.title}</span>
      </${tagName}>`;

    var children = items.filter(child => child.parent_id === (it.temp_id || it.item_id) && child.is_active);
    if (children.length > 0) {
      var submenuCols = it.submenu_columns || 1;
      var gridClass = submenuCols > 1 ? `grid grid-cols-${submenuCols} gap-4` : '';
      var minWidth = submenuCols > 1 ? `min-w-[${Math.min(submenuCols * 250, 1200)}px]` : 'min-w-[250px]';

      html += `<ul class="preview-dropdown absolute left-0 top-full mt-2 bg-white dark:bg-gray-800 shadow-2xl rounded-xl p-3 ${minWidth} border-2 border-gray-200 dark:border-gray-700 ${gridClass}">`;

      // Show CMS block content first if it's a CMS block type
      if (it.item_type === 'cms_block' && it.cms_block_id) {
        html += `<li class="mb-3 pb-3 border-b border-gray-200 dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${it.cms_block_id})</div>
          <div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>
        </li>`;
      }

      html += renderPreviewChildren(children, mode, it);
      html += '</ul>';
    } else if (it.item_type === 'cms_block' && it.cms_block_id) {
      // Show CMS block content in dropdown if no children
      html += `<div class="preview-dropdown absolute left-0 top-full mt-2 bg-white dark:bg-gray-800 shadow-2xl rounded-xl p-4 min-w-[300px] max-w-[500px] border-2 border-gray-200 dark:border-gray-700">
        <div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${it.cms_block_id})</div>
        <div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>
      </div>`;
    }

    html += '</li>';
  });

  html += '</ul></nav>';
  return html;
}

