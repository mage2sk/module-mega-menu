function renderIconPreview(icon, library) {
  if (library === 'emoji') {
    return `<span class="text-2xl">${icon}</span>`;
  } else if (library === 'material') {
    return `<span class="material-symbols-outlined">${icon}</span>`;
  } else {
    return `<i class="${icon}"></i>`;
  }
}

function getTooltipHtml(type) {
  return typeTooltips[type] || 'No description available';
}

function addItem() {
  items.push({
    item_id: null,
    temp_id: 'new_' + Date.now(),
    title: '',
    url: '',
    item_type: 'link',
    target: '_self',
    position: items.length,
    level: 0,
    is_active: 1,
    show_on_frontend: 1,
    parent_id: null,
    css_class: '',
    icon: '',
    icon_library: 'fontawesome',
    hover_effect: 'fade',
    submenu_columns: 1,
    background_color: '',
    text_color: '',
    category_id: null,
    cms_page_id: null,
    cms_block_id: null,
    custom_html: ''
  });
  render();
}

async function addChild(parentIdx) {
  var parent = items[parentIdx];

  // Prevent adding children to CMS Block and Custom HTML items
  if (parent.item_type === 'cms_block' || parent.item_type === 'custom_html') {
    await showAlert('Cannot add child items to CMS Block or Custom HTML items.\n\nThese item types cannot have children.', '❌', 'Error');
    return;
  }

  var newLevel = parent.level + 1;

  if (newLevel > 5) {
    await showAlert('Maximum nesting level (6) reached!', '❌', 'Error');
    return;
  }

  var parentId = parent.temp_id || parent.item_id;

  // Auto-expand parent if collapsed
  if (collapsedItems[parentId]) {
    delete collapsedItems[parentId];
  }

  // Find the last child of this parent (or the parent itself if no children)
  var insertIdx = parentIdx + 1;
  var parentIdToMatch = parentId;

  // Find all descendants of this parent
  for (var i = parentIdx + 1; i < items.length; i++) {
    var currentItem = items[i];

    // Check if this item is a descendant of the parent
    var isDescendant = false;
    var checkParent = currentItem.parent_id;

    while (checkParent) {
      if (checkParent === parentIdToMatch) {
        isDescendant = true;
        break;
      }
      var parentItem = items.find(it => (it.temp_id || it.item_id) === checkParent);
      if (!parentItem) break;
      checkParent = parentItem.parent_id;
    }

    if (isDescendant) {
      insertIdx = i + 1;
    } else {
      // Stop when we hit a non-descendant
      break;
    }
  }

  // Create new child item
  var newItem = {
    item_id: null,
    temp_id: 'new_' + Date.now(),
    title: '',
    url: '',
    item_type: 'link',
    target: '_self',
    position: insertIdx,
    level: newLevel,
    is_active: 1,
    show_on_frontend: 1,
    parent_id: parentId,
    css_class: '',
    icon: '',
    icon_library: 'fontawesome',
    hover_effect: 'fade',
    submenu_columns: 1,
    background_color: '',
    text_color: '',
    category_id: null,
    cms_page_id: null,
    cms_block_id: null,
    custom_html: ''
  };

  // Insert at the correct position (after parent and all its children)
  items.splice(insertIdx, 0, newItem);

  recalcPositions();
  render();

  // Auto-expand the new item for editing
  setTimeout(() => {
    var newItemIdx = items.findIndex(it => it.temp_id === newItem.temp_id);
    if (newItemIdx !== -1) {
      toggleExpand(newItemIdx);
    }
  }, 100);
}

function upd(i, f, v) { items[i][f] = v; }
function toggle(i) {
  var newValue = (items[i].show_on_frontend ?? 1) ? 0 : 1;
  items[i].show_on_frontend = newValue;
  items[i].is_active = newValue; // Keep is_active in sync
  render();
}
function genId() {
  if (!idGen) {
    document.getElementById('identifier').value = document.getElementById('title').value
      .toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
  }
}

async function del(i) {
  var delId = items[i].item_id || items[i].temp_id;

  // Find all children recursively
  var childrenToDelete = [];
  var findChildren = (parentId) => {
    items.forEach((it, idx) => {
      var itId = it.temp_id || it.item_id;
      if (it.parent_id === parentId) {
        childrenToDelete.push(idx);
        findChildren(itId);
      }
    });
  };
  findChildren(delId);

  var message = 'Delete this item?';
  if (childrenToDelete.length > 0) {
    message += '\n\nThis will also delete ' + childrenToDelete.length + ' child item(s).';
  }

  var confirmed = await showConfirm(message, '⚠️', 'Confirm Delete');
  if (!confirmed) return;

  // Sort indices in descending order to delete from end first
  childrenToDelete.sort((a, b) => b - a);

  // Delete all children first
  childrenToDelete.forEach(idx => {
    items.splice(idx, 1);
  });

  // Find the new index of parent item after children deletion
  var newParentIdx = items.findIndex(it => (it.item_id || it.temp_id) === delId);
  if (newParentIdx !== -1) {
    items.splice(newParentIdx, 1);
  }

  recalcPositions();
  render();
}

function recalcPositions() { items.forEach((it, idx) => it.position = idx); }

// DRAG AND DROP - IMPROVED VERSION
var dropZone = null;
var nestMode = false;

function dragStart(e, idx) {
  dragEl = e.target;
  dragIdx = idx;

  // Find the actual item container
  while (dragEl && !dragEl.dataset.i) {
    dragEl = dragEl.parentElement;
  }

  if (!dragEl) return;

  dragEl.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', idx);

  // Create drag image
  var dragImage = dragEl.cloneNode(true);
  dragImage.style.opacity = '0.8';
  document.body.appendChild(dragImage);
  dragImage.style.position = 'absolute';
  dragImage.style.top = '-1000px';
  e.dataTransfer.setDragImage(dragImage, 0, 0);
  setTimeout(() => document.body.removeChild(dragImage), 0);
}

function dragEnd(e) {
  if (dragEl) dragEl.classList.remove('dragging');
  if (dropTarget) {
    dropTarget.classList.remove('drop-indicator', 'drop-invalid');
    dropTarget.style.borderTop = '';
    dropTarget.style.borderBottom = '';
  }

  if (dragTimer) clearTimeout(dragTimer);

  dragEl = null;
  dragIdx = -1;
  dropTarget = null;
  dropZone = null;
  nestMode = false;

  // Remove all drop indicators
  document.querySelectorAll('.drop-indicator, .drop-invalid').forEach(el => {
    el.classList.remove('drop-indicator', 'drop-invalid');
    el.style.borderTop = '';
    el.style.borderBottom = '';
  });
}

function dragLeave(e) {
  var tgt = e.target;

  // Find the item container
  while (tgt && !tgt.dataset.i) {
    tgt = tgt.parentElement;
  }

  if (tgt && tgt.dataset.i) {
    tgt.classList.remove('drop-indicator', 'drop-invalid');
    tgt.style.borderTop = '';
    tgt.style.borderBottom = '';
  }

  if (dragTimer) {
    clearTimeout(dragTimer);
    dragTimer = null;
  }

  nestMode = false;
}

function dragOver(e, idx) {
  e.preventDefault();
  e.stopPropagation();

  if (dragIdx === -1 || dragIdx === idx) return;

  // Find the target item container
  var tgt = e.target;
  while (tgt && !tgt.dataset.i) {
    tgt = tgt.parentElement;
  }

  if (!tgt || !tgt.dataset.i) return;

  // Check if we're dragging a parent onto its own child (prevent circular reference)
  var draggedId = items[dragIdx].temp_id || items[dragIdx].item_id;
  var targetItem = items[idx];
  var isCircular = false;

  // Check if target is a descendant of dragged item
  var checkParent = targetItem.parent_id;
  while (checkParent) {
    if (checkParent === draggedId) {
      isCircular = true;
      break;
    }
    var parentItem = items.find(it => (it.temp_id || it.item_id) === checkParent);
    if (!parentItem) break;
    checkParent = parentItem.parent_id;
  }

  // Clear previous drop target
  if (dropTarget && dropTarget !== tgt) {
    dropTarget.classList.remove('drop-indicator', 'drop-invalid');
    dropTarget.style.borderTop = '';
    dropTarget.style.borderBottom = '';
  }

  dropTarget = tgt;

  // Clear previous timer
  if (dragTimer) clearTimeout(dragTimer);

  // Determine drop position based on mouse Y position
  var rect = tgt.getBoundingClientRect();
  var mouseY = e.clientY;
  var middleY = rect.top + (rect.height / 2);

  // Immediate visual feedback for reorder
  tgt.classList.remove('drop-indicator', 'drop-invalid');

  if (mouseY < middleY) {
    // Drop above
    tgt.style.borderTop = '3px solid #3b82f6';
    tgt.style.borderBottom = '';
  } else {
    // Drop below
    tgt.style.borderBottom = '3px solid #3b82f6';
    tgt.style.borderTop = '';
  }

  // Start timer for nesting (300ms hover)
  dragTimer = setTimeout(() => {
    tgt.style.borderTop = '';
    tgt.style.borderBottom = '';

    if (isCircular) {
      tgt.classList.add('drop-invalid');
      tgt.classList.remove('drop-indicator');
      nestMode = false;
      return;
    }

    // Prevent nesting into CMS Block or Custom HTML items
    if (targetItem.item_type === 'cms_block' || targetItem.item_type === 'custom_html') {
      tgt.classList.add('drop-invalid');
      tgt.classList.remove('drop-indicator');
      nestMode = false;
      return;
    }

    var newLvl = items[idx].level + 1;

    if (newLvl > 5) {
      tgt.classList.add('drop-invalid');
      tgt.classList.remove('drop-indicator');
      nestMode = false;
    } else {
      tgt.classList.add('drop-indicator');
      tgt.classList.remove('drop-invalid');
      nestMode = true;
    }
  }, 300);
}

async function drop(e, idx) {
  e.preventDefault();
  e.stopPropagation();

  if (dragIdx === -1 || dragIdx === idx) {
    dragEnd(e);
    return;
  }

  if (dragTimer) {
    clearTimeout(dragTimer);
    dragTimer = null;
  }

  // Remove border indicators
  if (dropTarget) {
    dropTarget.style.borderTop = '';
    dropTarget.style.borderBottom = '';
  }

  var isNestDrop = nestMode && dropTarget && dropTarget.classList.contains('drop-indicator');

  if (isNestDrop) {
    // NEST MODE: Make dragged item a child of target
    var newLvl = items[idx].level + 1;

    if (newLvl > 5) {
      await showAlert('Cannot nest: Maximum 6 levels allowed', '❌', 'Error');
      dragEnd(e);
      render();
      return;
    }

    // Check for circular reference
    var draggedId = items[dragIdx].temp_id || items[dragIdx].item_id;
    var targetItem = items[idx];
    var isCircular = false;

    var checkParent = targetItem.parent_id;
    while (checkParent) {
      if (checkParent === draggedId) {
        isCircular = true;
        break;
      }
      var parentItem = items.find(it => (it.temp_id || it.item_id) === checkParent);
      if (!parentItem) break;
      checkParent = parentItem.parent_id;
    }

    if (isCircular) {
      await showAlert('Cannot nest: This would create a circular reference', '❌', 'Error');
      dragEnd(e);
      render();
      return;
    }

    var draggedItem = items[dragIdx];
    var targetId = items[idx].temp_id || items[idx].item_id;

    draggedItem.parent_id = targetId;
    draggedItem.level = newLvl;

    // Update all children recursively
    var childIds = [draggedItem.temp_id || draggedItem.item_id];
    var updateChildren = (lvl) => {
      items.forEach(it => {
        if (childIds.includes(it.parent_id)) {
          it.level = lvl + 1;
          if (it.level > 5) {
            it.level = 0;
            it.parent_id = null;
          } else {
            childIds.push(it.temp_id || it.item_id);
            updateChildren(lvl + 1);
          }
        }
      });
    };
    updateChildren(newLvl);

    recalcPositions();
  } else {
    // REORDER MODE: Move item to new position
    // Determine drop position based on mouse position
    var rect = dropTarget.getBoundingClientRect();
    var mouseY = e.clientY;
    var middleY = rect.top + (rect.height / 2);

    var temp = items.splice(dragIdx, 1)[0];
    var newIdx;

    if (mouseY < middleY) {
      // Drop above target
      newIdx = idx;
      if (dragIdx < idx) newIdx--;
    } else {
      // Drop below target
      newIdx = idx;
      if (dragIdx < idx) newIdx--;
      newIdx++;
    }

    items.splice(newIdx, 0, temp);
    // IMPORTANT: Maintain parent_id when reordering - don't change it
    recalcPositions();
  }

  dragEnd(e);
  render();
}

// CATEGORY IMPORT
async function importCategories() {
  var confirmed = await showConfirm('Import all active categories from Magento?\n\nThis will add categories to the menu while preserving existing items.', '📥', 'Import Categories');
  if (!confirmed) return;

  var maxLevel = prompt('Maximum category level to import (0 = all levels, 1 = only top level, etc.):', '0');
  if (maxLevel === null) return;

  fetch(importCategoriesUrl + '?max_level=' + maxLevel)
    .then(r => r.json())
    .then(async d => {
      if (d.success) {
        items = items.concat(d.items);
        recalcPositions();
        initializeCollapsedState();
        render();
        await showAlert('Successfully imported ' + d.count + ' categories!', '✅', 'Success');
      } else {
        await showAlert('Error: ' + (d.message || 'Failed to import categories'), '❌', 'Error');
      }
    })
    .catch(async e => {
      await showAlert('Error importing categories: ' + e.message, '❌', 'Error');
    });
}

