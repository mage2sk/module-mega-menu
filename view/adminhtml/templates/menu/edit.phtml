function renderIcons(filter = '') {
  var list = document.getElementById('iconList');
  var filtered = iconData.filter(it => {
    var name = it.name || '';
    return name.toLowerCase().includes(filter.toLowerCase());
  });

  if (!filtered.length) {
    list.innerHTML = '<div class="col-span-6 text-center py-20 text-gray-500">No icons found</div>';
    return;
  }

  list.innerHTML = filtered.map(it => {
