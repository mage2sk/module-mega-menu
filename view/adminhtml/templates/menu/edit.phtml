        html += `<a href="#" class="mobile-accordion-toggle flex items-center justify-between px-4 py-3 font-semibold text-base ${hoverClass} rounded-lg transition-all" data-target="${accordionId}" style="${itemStyle}">
          <span class="flex items-center gap-2">${iconHtml ? iconHtml + ' ' : ''}${it.title}</span>
          <span class="mobile-accordion-btn text-gray-400">▼</span>
        </a>`;
        html += `<div id="${accordionId}" class="mobile-accordion-content pl-4">`;
        html += '<div class="mb-3 pb-3 border-b border-gray-200 dark:border-gray-700 px-4 py-2">';
        html += `<div class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">CMS Block Content (ID: ${it.cms_block_id})</div>`;
        html += '<div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>';
        html += '</div>';
        html += '</div>';
      } else {
        var hasUrl = it.url && it.url.trim() !== '';
        var tagName = 'a';
        var hrefAttr = `href="${it.url || '#'}" target="${it.target || '_self'}"`;

        html += `<${tagName} ${hrefAttr} class="flex items-center justify-between px-4 py-3 font-semibold text-base ${hoverClass} rounded-lg transition-all" style="${itemStyle}">
          <span class="flex items-center gap-2">${iconHtml ? iconHtml + ' ' : ''}${it.title}</span>
        </${tagName}>`;
      }
