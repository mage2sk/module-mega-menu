function loadIcons(library) {
  iconLibrary = library;
  var list = document.getElementById('iconList');
  list.innerHTML = '<div class="col-span-6 text-center py-20 text-gray-500">Loading...</div>';

  fetch(getIconsUrl + '?library=' + library)
    .then(r => r.json())
    .then(async d => {
      if (d.success) {
        iconData = d.icons;
        renderIcons();
      } else {
        await showAlert('Error loading icons', '❌', 'Error');
        closeIconPicker();
      }
    })
    .catch(async e => {
      await showAlert('Error loading icons', '❌', 'Error');
      closeIconPicker();
    });
