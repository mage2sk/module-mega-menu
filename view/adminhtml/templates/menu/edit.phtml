function closePicker() {
  document.getElementById('pickerModal').classList.add('hidden');
  document.getElementById('pickerModal').classList.remove('flex');
  pickerData = [];
  pickerIdx = -1;
}

function loadPickerData(type) {
  var list = document.getElementById('pickerList');
  list.innerHTML = '<div class="text-center py-20 text-gray-500">Loading...</div>';

  fetch(getCategoriesUrl + '?type=' + type)
    .then(r => r.json())
    .then(async d => {
      if (!d.success) {
        await showAlert('Error loading data', '❌', 'Error');
        closePicker();
        return;
      }

      // Use hierarchical data if available
      if (type === 'category' && d.data.hierarchical) {
        pickerData = d.data.flat;
        renderPickerTree(d.data.hierarchical);
      } else {
        pickerData = d.data;
        renderPicker();
      }
    })
    .catch(async e => {
      await showAlert('Error loading data', '❌', 'Error');
      closePicker();
    });
}

function renderPicker(filter = '') {
  var list = document.getElementById('pickerList');
  var filtered = pickerData.filter(it => {
    var name = it.name || it.title || '';
    return name.toLowerCase().includes(filter.toLowerCase());
  });

  if (!filtered.length) {
    list.innerHTML = '<div class="text-center py-20 text-gray-500">No items found</div>';
    return;
  }

  list.innerHTML = filtered.map(it => {
    var title = it.name || it.title;
    var url = it.url || '';
    var indent = it.level ? 'ml-' + (it.level * 6) : '';
    var badge = it.level !== undefined ? `<span class="px-2 py-1 bg-green-500/20 text-green-600 rounded-lg text-xs font-bold">L${it.level}</span>` : '';

    return `<div onclick='selectPickerItem(${JSON.stringify(it).replace(/'/g, "\\'")})'
                 class="${indent} p-4 bg-gray-50 dark:bg-gray-700 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 border-2 border-gray-200 dark:border-gray-600 hover:border-indigo-400 rounded-xl cursor-pointer transition-all">
      <div class="flex items-center justify-between">
        <div class="flex-1">
          <div class="font-bold text-gray-900 dark:text-white">${title}</div>
          ${url ? `<div class="text-sm text-gray-600 dark:text-gray-400 mt-1">${url}</div>` : ''}
        </div>
        ${badge}
      </div>
    </div>`;
  }).join('');
}

function renderPickerTree(tree, level = 0) {
  var list = document.getElementById('pickerList');
  var html = '';

  tree.forEach(cat => {
    var indent = level > 0 ? 'ml-' + (level * 6) : '';
    var hasChildren = cat.children && cat.children.length > 0;
    var expandIcon = hasChildren ? '📁' : '📄';

    html += `<div class="${indent} mb-2">
      <div onclick='selectPickerItem(${JSON.stringify(cat).replace(/'/g, "\\'")})'
           class="p-4 bg-gray-50 dark:bg-gray-700 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 border-2 border-gray-200 dark:border-gray-600 hover:border-indigo-400 rounded-xl cursor-pointer transition-all">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span>${expandIcon}</span>
            <span class="font-bold text-gray-900 dark:text-white">${cat.name}</span>
          </div>
          <span class="px-2 py-1 bg-green-500/20 text-green-600 rounded-lg text-xs font-bold">L${cat.level}</span>
        </div>
      </div>`;

    if (hasChildren) {
      html += '<div class="ml-6 mt-2">';
      cat.children.forEach(child => {
        html += renderPickerTreeItem(child, level + 1);
      });
      html += '</div>';
    }

    html += '</div>';
  });

  list.innerHTML = html;
}

function renderPickerTreeItem(cat, level) {
  var indent = '';
  var hasChildren = cat.children && cat.children.length > 0;
  var expandIcon = hasChildren ? '📁' : '📄';

  var html = `<div class="mb-2">
    <div onclick='selectPickerItem(${JSON.stringify(cat).replace(/'/g, "\\'")})'
         class="p-4 bg-gray-50 dark:bg-gray-700 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 border-2 border-gray-200 dark:border-gray-600 hover:border-indigo-400 rounded-xl cursor-pointer transition-all">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span>${expandIcon}</span>
          <span class="font-bold text-gray-900 dark:text-white">${cat.name}</span>
        </div>
        <span class="px-2 py-1 bg-green-500/20 text-green-600 rounded-lg text-xs font-bold">L${cat.level}</span>
      </div>
    </div>`;

  if (hasChildren) {
    html += '<div class="ml-6 mt-2">';
    cat.children.forEach(child => {
      html += renderPickerTreeItem(child, level + 1);
    });
    html += '</div>';
  }

  html += '</div>';
  return html;
}

function filterPicker() {
  renderPicker(document.getElementById('pickerSearch').value);
}

function selectPickerItem(item) {
  var idx = pickerIdx;
  items[idx].title = item.name || item.title || items[idx].title;
  items[idx].url = item.url || items[idx].url;

  if (item.id) {
    if (items[idx].item_type === 'category') {
      items[idx].category_id = item.id;
    } else if (items[idx].item_type === 'cms_page') {
      items[idx].cms_page_id = item.id;
    } else if (items[idx].item_type === 'cms_block') {
      items[idx].cms_block_id = item.id;
    }
  }

  if (item.identifier && !items[idx].url) {
    items[idx].url = '/' + item.identifier;
  }

  closePicker();
  render();
}

