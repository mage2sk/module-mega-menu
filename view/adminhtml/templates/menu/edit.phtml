        html += '<div class="text-gray-700 dark:text-gray-300">CMS block content will be displayed here on the frontend.</div>';
        html += '</div>';
      }

      html += renderMobileAccordionChildren(grandchildren);
      html += '</div>';
    } else {
      // If it's a CMS block, treat it like it has children (show accordion)
      if (child.item_type === 'cms_block' && child.cms_block_id) {
        html += `<a href="#" class="mobile-accordion-toggle flex items-center justify-between px-4 py-2.5 text-base ${hoverClass} rounded-lg transition-all" data-target="${accordionId}" style="${itemStyle}">
          <span class="flex items-center gap-2">${childIcon ? childIcon + ' ' : ''}${child.title}</span>
          <span class="mobile-accordion-btn text-gray-400 text-sm">▼</span>
        </a>`;
        html += `<div id="${accordionId}" class="mobile-accordion-content pl-4">`;
