// Initialize all items with children as collapsed by default
function initializeCollapsedState() {
  items.forEach(item => {
    var itemId = item.temp_id || item.item_id;
    // Check if this item has children
    var hasKids = items.some(it => it.parent_id === itemId);
    if (hasKids) {
      collapsedItems[itemId] = true;
    }
  });
}

// Modal Alert/Confirm Functions
function showAlert(message, icon = '⚠️', title = 'Alert') {
  return new Promise((resolve) => {
    document.getElementById('alertTitleText').textContent = title;
    document.getElementById('alertIcon').textContent = icon;
    document.getElementById('alertMessage').textContent = message;
    document.getElementById('alertCancelBtn').classList.add('hidden');
    document.getElementById('alertOkBtn').textContent = 'OK';
    document.getElementById('alertModal').classList.remove('hidden');
    document.getElementById('alertModal').classList.add('flex');
    alertCallback = resolve;
  });
}

function showConfirm(message, icon = '❓', title = 'Confirm') {
  return new Promise((resolve) => {
    document.getElementById('alertTitleText').textContent = title;
    document.getElementById('alertIcon').textContent = icon;
    document.getElementById('alertMessage').textContent = message;
    document.getElementById('alertCancelBtn').classList.remove('hidden');
    document.getElementById('alertOkBtn').textContent = 'Confirm';
    document.getElementById('alertModal').classList.remove('hidden');
    document.getElementById('alertModal').classList.add('flex');
    alertCallback = resolve;
  });
}

function closeAlert(result) {
  document.getElementById('alertModal').classList.add('hidden');
  document.getElementById('alertModal').classList.remove('flex');
  if (alertCallback) {
    alertCallback(result);
    alertCallback = null;
  }
}

