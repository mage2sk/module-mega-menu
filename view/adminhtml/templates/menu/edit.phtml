function render() {
  var h = document.getElementById('items');
  if (!items.length) {
    h.innerHTML = `<div class="text-center py-20 border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl">
      <div class="text-6xl mb-4 animate-bounce">📋</div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">No menu items yet</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Click "Add Item" or "Import Categories" to get started</p>
    </div>`;
    return;
  }

  // Build HTML considering collapsed state
  var html = '';
  items.forEach((it, i) => {
    var itemId = it.temp_id || it.item_id;

    // Check if any ancestor is collapsed
    if (isAnyAncestorCollapsed(it)) {
      return; // Skip rendering if any ancestor is collapsed
    }

    html += renderItem(it, i);
  });

  h.innerHTML = html;
}

function isAnyAncestorCollapsed(item) {
  var currentParentId = item.parent_id;

  while (currentParentId) {
    if (collapsedItems[currentParentId]) {
      return true;
    }

    // Find the parent item
    var parentItem = items.find(it => (it.temp_id || it.item_id) === currentParentId);
    if (!parentItem) break;

    currentParentId = parentItem.parent_id;
  }

  return false;
}

function toggleCollapse(i) {
  var item = items[i];
  var itemId = item.temp_id || item.item_id;

  if (collapsedItems[itemId]) {
    delete collapsedItems[itemId];
  } else {
    collapsedItems[itemId] = true;
  }

  render();
}

function toggleExpand(i) {
  var item = items[i];
  var itemId = item.temp_id || item.item_id;

  if (expandedItems[itemId]) {
    delete expandedItems[itemId];
  } else {
    expandedItems[itemId] = true;
  }

  render();
}

function hasChildren(itemId) {
  return items.some(it => it.parent_id === itemId);
}

