<script>
var formKey = document.querySelector('input[name="form_key"]').value;

// Toggle Dropdown
function toggleDropdown(id) {
  const dropdown = document.getElementById('dropdown-' + id);
  const allDropdowns = document.querySelectorAll('[id^="dropdown-"]');

  allDropdowns.forEach(d => {
    if (d !== dropdown) d.classList.add('hidden');
  });

  dropdown.classList.toggle('hidden');
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(e) {
  if (!e.target.closest('[onclick^="toggleDropdown"]') && !e.target.closest('[id^="dropdown-"]')) {
    document.querySelectorAll('[id^="dropdown-"]').forEach(d => d.classList.add('hidden'));
  }
});

// Delete Menu
function deleteMenu(id, title) {
  if (!confirm('Delete "' + title + '"?\n\nThis will permanently delete all menu items.')) return;

  fetch('<?= $block->escapeUrl($block->getDeleteUrl()) ?>?ajax=1', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'menu_id=' + id + '&form_key=' + formKey
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      showNotification('Menu deleted successfully', 'success');
      setTimeout(() => location.reload(), 1000);
    } else {
      showNotification(d.message || 'Failed to delete menu', 'error');
    }
  });
}

// Toggle Menu
function toggleMenu(id, enable) {
  fetch('<?= $block->escapeUrl($block->getToggleUrl()) ?>?ajax=1', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'menu_id=' + id + '&is_active=' + (enable ? '1' : '0') + '&form_key=' + formKey
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      showNotification('Menu ' + (enable ? 'enabled' : 'disabled'), 'success');
      setTimeout(() => location.reload(), 1000);
    } else {
      showNotification(d.message || 'Failed to toggle menu', 'error');
    }
  });
}

// Duplicate Menu
function duplicateMenu(id, title) {
  var newTitle = prompt('Enter name for duplicated menu:', title + ' (Copy)');
  if (!newTitle) return;

  fetch('<?= $block->escapeUrl($block->getDuplicateUrl()) ?>?ajax=1', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'menu_id=' + id + '&new_title=' + encodeURIComponent(newTitle) + '&form_key=' + formKey
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      showNotification('Menu duplicated successfully', 'success');
      setTimeout(() => location.reload(), 1000);
    } else {
      showNotification(d.message || 'Failed to duplicate menu', 'error');
    }
  });
}

// Export Menu
function exportMenu(id, identifier) {
  fetch('<?= $block->escapeUrl($block->getExportUrl()) ?>?ajax=1&menu_id=' + id + '&form_key=' + formKey)
  .then(r => r.json())
  .then(d => {
    if (d.success && d.data) {
      var dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(d.data, null, 2));
      var downloadAnchor = document.createElement('a');
      downloadAnchor.setAttribute("href", dataStr);
      downloadAnchor.setAttribute("download", "menu_" + identifier + "_" + Date.now() + ".json");
      document.body.appendChild(downloadAnchor);
      downloadAnchor.click();
      downloadAnchor.remove();
      showNotification('Menu exported successfully', 'success');
    } else {
      showNotification(d.message || 'Failed to export menu', 'error');
    }
  });
}

// Show Notification
function showNotification(message, type) {
  var bgColor = type === 'success' ? 'bg-green-500' : 'bg-red-500';
  var icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
  var notification = document.createElement('div');
  notification.className = 'fixed top-4 right-4 ' + bgColor + ' text-white px-5 py-3 rounded-lg shadow-lg z-50 flex items-center gap-3 animate-slide-down';
  notification.innerHTML = '<i class="fas ' + icon + '"></i><span>' + message + '</span>';
  document.body.appendChild(notification);

  setTimeout(() => {
    notification.style.opacity = '0';
    notification.style.transform = 'translateY(-20px)';
    notification.style.transition = 'all 0.3s ease';
    setTimeout(() => notification.remove(), 300);
  }, 3000);
}

// Import Modal
var importFileData = null;

function openImportModal() {
  document.getElementById('importModal').classList.remove('hidden');
}

function closeImportModal() {
  document.getElementById('importModal').classList.add('hidden');
  document.getElementById('importFile').value = '';
  document.getElementById('fileName').textContent = '';
  importFileData = null;
}

function toggleMenuSelector() {
  var action = document.querySelector('input[name="importAction"]:checked').value;
  document.getElementById('menuSelector').classList.toggle('hidden', action !== 'replace');
}

function handleFileSelect(event) {
  var file = event.target.files[0];
  if (!file || !file.name.endsWith('.json')) {
    showNotification('Please select a JSON file', 'error');
    return;
  }

  document.getElementById('fileName').textContent = '✓ ' + file.name;

  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      importFileData = JSON.parse(e.target.result);
      showNotification('File loaded successfully', 'success');
    } catch (error) {
      showNotification('Invalid JSON file', 'error');
      importFileData = null;
    }
  };
  reader.readAsText(file);
}

function performImport() {
  if (!importFileData) {
    showNotification('Please select a file first', 'error');
    return;
  }

  var action = document.querySelector('input[name="importAction"]:checked').value;
  var replaceMenuId = action === 'replace' ? document.getElementById('replaceMenuId').value : null;

  if (action === 'replace' && !replaceMenuId) {
    showNotification('Please select a menu to replace', 'error');
    return;
  }

  var formData = new FormData();
  formData.append('menu_data', JSON.stringify(importFileData));
  formData.append('action', action);
  formData.append('replace_menu_id', replaceMenuId || '');
  formData.append('form_key', formKey);

  fetch('<?= $block->escapeUrl($block->getImportUrl()) ?>?ajax=1', {
    method: 'POST',
    body: formData
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      showNotification('Menu imported successfully', 'success');
      closeImportModal();
      setTimeout(() => location.reload(), 1000);
    } else {
      showNotification(d.message || 'Failed to import menu', 'error');
    }
  });
}
</script>
