<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Remove ALL regular menu blocks so only preview renders -->
        <referenceBlock name="panth.megamenu.hyva" remove="true"/>
        <referenceBlock name="panth.megamenu.luma" remove="true"/>
        <referenceBlock name="panth.megamenu.alpine.js" remove="true"/>
        <referenceBlock name="panth.megamenu.dynamic.css" remove="true"/>
        <!-- Also remove default Hyva topmenu children -->
        <referenceBlock name="topmenu_desktop" remove="true"/>
        <referenceBlock name="topmenu_mobile" remove="true"/>

        <!-- Add preview block -->
        <referenceBlock name="topmenu_generic">
            <block class="Panth\MegaMenu\Block\Preview"
                   name="panth.megamenu.preview"
                   template="Panth_MegaMenu::preview.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Panth\MegaMenu\ViewModel\Menu</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
