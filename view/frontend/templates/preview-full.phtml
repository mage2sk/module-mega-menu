            <?php
            endif;
            ?>

            <?= /* @noEscape */ $block->getLayout()
                ->createBlock(\Panth\MegaMenu\Block\Preview::class)
                ->setTemplate('Panth_MegaMenu::pmenu/menu.phtml')
                ->setData('menu_id', $block->getMenuId())
                ->setData('theme_helper', $block->getData('theme_helper'))
                ->toHtml() ?>
        </div>
    </div>

    <!-- Load RequireJS -->
    <script src="<?= $escaper->escapeUrl($requireJsUrl) ?>"></script>

    <script>
        // Configure RequireJS for preview
        require.config({
            paths: {
                'jquery': 'jquery',
                'Panth_MegaMenu/js/megamenu': 'Panth_MegaMenu/js/megamenu'
            },
            shim: {
                'Panth_MegaMenu/js/megamenu': {
                    deps: ['jquery']
                }
            }
        });

        // Load jQuery first, then initialize MegaMenu
        require(['jquery'], function($) {
            console.log('Preview: jQuery loaded');

            // Load MegaMenu widget
            require(['Panth_MegaMenu/js/megamenu'], function(megamenuWidget) {
                console.log('Preview: MegaMenu widget loaded');

                $(document).ready(function() {
                    // Find any menu element (supports dynamic ID)
                    var menuElement = document.querySelector('.pmenu-wrapper');
                    if (menuElement) {
                        console.log('Preview: Menu element found, initializing widget...', menuElement.id);

                        // Initialize the widget (Magento pattern: config, element)
                        megamenuWidget({}, menuElement);

                        console.log('Preview: MegaMenu initialized successfully');
                    } else {
                        console.error('Preview: Menu element .pmenu-wrapper not found!');
                    }
                });
            });
        });
    </script>
</body>
