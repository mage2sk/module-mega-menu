            // Check if menu tree exists (for error display only)
            $menuTree = $block->getCurrentMenuTree();

            if (empty($menuTree)):
            ?>
                <div style="padding: 40px; text-align: center; background: #fff3cd; border: 2px solid #ffc107; border-radius: 8px; margin: 20px;">
                    <h2 style="color: #856404; margin: 0 0 10px 0;">⚠️ No Menu Items Found</h2>
