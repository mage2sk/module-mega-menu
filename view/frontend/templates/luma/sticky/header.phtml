<script type="text/javascript">
require([
    'jquery',
    'jquery-ui-modules/widget'
], function($) {
    'use strict';

    $.widget('panth.stickyHeader', {
        options: {
            stickyOffset: <?= (int) $stickyOffset ?>,
            animationSpeed: <?= (int) $block->getAnimationSpeed() ?>,
            showOnScrollUp: <?= $block->getShowOnScrollUp() ? 'true' : 'false' /* @noEscape */ ?>,
            hideOnScrollDown: <?= $block->getHideOnScrollDown() ? 'true' : 'false' /* @noEscape */ ?>,
            transparentOnTop: <?= $block->getTransparentOnTop() ? 'true' : 'false' /* @noEscape */ ?>
        },

        _create: function() {
            this.lastScrollTop = 0;
            this.isSticky = false;
            this.isVisible = true;
            this.ticking = false;

            this._bind();
            this._checkPosition();
        },

        _bind: function() {
            var self = this;

            // Scroll event with requestAnimationFrame for performance
            $(window).on('scroll.stickyHeader', function() {
                if (!self.ticking) {
                    window.requestAnimationFrame(function() {
                        self._checkPosition();
                        self.ticking = false;
                    });
                    self.ticking = true;
                }
            });

            // Resize event
            $(window).on('resize.stickyHeader', $.proxy(this._checkPosition, this));

            // Search toggle
            this.element.on('click', '[data-action="toggle-search"]', function(e) {
                e.preventDefault();
                self._toggleSearch();
            });

            // Close search on outside click
            $(document).on('click.stickyHeader', function(e) {
                if (!$(e.target).closest('.sticky-search, .sticky-search-form').length) {
                    self._closeSearch();
                }
            });

            // ESC key to close search
            $(document).on('keydown.stickyHeader', function(e) {
                if (e.keyCode === 27) {
                    self._closeSearch();
                }
            });
        },

        _checkPosition: function() {
            var scrollTop = $(window).scrollTop();
            var scrollDirection = scrollTop > this.lastScrollTop ? 'down' : 'up';

            // Check if should be sticky
            if (scrollTop >= this.options.stickyOffset) {
                if (!this.isSticky) {
                    this._makeSticky();
                }

                // Show/hide based on scroll direction
                if (this.options.showOnScrollUp && scrollDirection === 'up' && !this.isVisible) {
                    this._show();
                } else if (this.options.hideOnScrollDown && scrollDirection === 'down' && this.isVisible) {
                    this._hide();
                }
            } else {
                if (this.isSticky) {
                    this._makeNormal();
                }

                // Transparent on top
                if (this.options.transparentOnTop && scrollTop === 0) {
                    this.element.addClass('transparent');
                } else {
                    this.element.removeClass('transparent');
                }
            }

            this.lastScrollTop = scrollTop;
        },

        _makeSticky: function() {
            this.isSticky = true;
            this.element.addClass('sticky active');
            this.element.css('top', '0');
            $('body').addClass('has-sticky-header');
        },

        _makeNormal: function() {
            this.isSticky = false;
            this.isVisible = true;
            this.element.removeClass('sticky active hidden');
            this.element.css('top', '');
            $('body').removeClass('has-sticky-header');
        },

        _show: function() {
            this.isVisible = true;
            this.element.removeClass('hidden').addClass('shown');
        },

        _hide: function() {
            this.isVisible = false;
            this.element.removeClass('shown').addClass('hidden');
            this._closeSearch();
        },

        _toggleSearch: function() {
            var $searchForm = this.element.find('.sticky-search-form');
            var $searchInput = $searchForm.find('input[type="search"]');

            if ($searchForm.is(':visible')) {
                $searchForm.slideUp(this.options.animationSpeed);
            } else {
                $searchForm.slideDown(this.options.animationSpeed, function() {
                    $searchInput.focus();
                });
            }
        },

        _closeSearch: function() {
            var $searchForm = this.element.find('.sticky-search-form');
            if ($searchForm.is(':visible')) {
                $searchForm.slideUp(this.options.animationSpeed);
            }
        },

        _destroy: function() {
            $(window).off('.stickyHeader');
            $(document).off('.stickyHeader');
            this.element.removeClass('sticky active hidden shown transparent');
            $('body').removeClass('has-sticky-header');
        }
    });

    // Initialize widget
    $(document).ready(function() {
        $('#<?= $escaper->escapeJs($uniqueId) ?>').stickyHeader({
            stickyOffset: <?= (int) $stickyOffset ?>,
            animationSpeed: <?= (int) $block->getAnimationSpeed() ?>,
            showOnScrollUp: <?= $block->getShowOnScrollUp() ? 'true' : 'false' /* @noEscape */ ?>,
            hideOnScrollDown: <?= $block->getHideOnScrollDown() ? 'true' : 'false' /* @noEscape */ ?>,
            transparentOnTop: <?= $block->getTransparentOnTop() ? 'true' : 'false' /* @noEscape */ ?>
        });
    });
});
</script>

