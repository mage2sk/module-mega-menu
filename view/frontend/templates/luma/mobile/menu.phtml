<?php
/**
 * Panth MegaMenu - Mobile Menu Template (Luma)
 *
 * Mobile menu with Magento-style accordion pattern for all nesting levels
 * Replaces slide navigation with standard accordion collapse/expand
 *
 * @category    Panth
 * @package     Panth_MegaMenu
 * @copyright   Copyright (c) 2025 Panth InfoTech
 * @license     Proprietary
 *
 * @var \Panth\MegaMenu\Block\Menu $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Panth\MegaMenu\Block\Menu $block */
$menuTree = $block->getCurrentMenuTree();
$uniqueId = uniqid('mobile-menu-');

// Return early if no menu items
if (empty($menuTree)) {
    return;
}

// Helper function to get item value (for consistency with array/object access)
$getValue = function($item, $key, $method = null, $default = null) {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    return $method && method_exists($item, $method) ? $item->$method() : $default;
};

// Animation speed from config (default 300ms)
$animationSpeed = 300;
?>

<?php if ($menuTree && count($menuTree) > 0): ?>
<div class="panth-megamenu-mobile-container" id="<?= $escaper->escapeHtmlAttr($uniqueId) ?>">
    <!-- Mobile Menu Panel -->
    <nav class="navigation mobile-navigation"
         id="<?= $escaper->escapeHtmlAttr($uniqueId . '-nav') ?>"
         role="navigation"
         aria-label="<?= $escaper->escapeHtmlAttr(__('Mobile Menu')) ?>">

        <!-- Menu Header -->
        <div class="mobile-menu-header">
            <button type="button"
                    class="action close"
                    data-action="close-nav"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Close Menu')) ?>">
                <span class="close-icon" aria-hidden="true">&times;</span>
            </button>
            <h2 class="mobile-menu-title">
                <?= $escaper->escapeHtml(__('Menu')) ?>
            </h2>
        </div>

        <!-- Menu Items - Recursive accordion for all levels -->
        <div class="mobile-menu-content">
            <ul class="mobile-nav-list level0" role="menu">
                <?php foreach ($menuTree as $index => $item): ?>
                    <?php
                    $isActive = $getValue($item, 'is_active', 'getIsActive', true);
                    if (!$isActive) {
                        continue;
                    }

                    $title = $escaper->escapeHtml($getValue($item, 'title', 'getTitle', ''));
                    $url = $escaper->escapeUrl($getValue($item, 'url', 'getUrl', '#'));
                    $children = $getValue($item, 'children', 'getChildren', []);
                    $hasChildren = !empty($children);
                    $icon = $getValue($item, 'icon', 'getIcon', '');
                    $itemId = $getValue($item, 'item_id', 'getItemId');
                    ?>

                    <li class="mobile-nav-item level0 <?= $hasChildren ? 'parent has-children' : '' /* @noEscape */ ?>"
                        data-item-id="<?= (int) $itemId ?>"
                        data-level="0">
                        <a href="<?= /* @noEscape */ $url ?>" class="mobile-nav-link level0">
                            <span class="link-content">
                                <?php if ($icon): ?>
                                    <span class="menu-icon <?= $escaper->escapeHtmlAttr($icon) ?>" aria-hidden="true"></span>
                                <?php endif; ?>
                                <span class="menu-label"><?= /* @noEscape */ $title ?></span>
                            </span>
                            <?php if ($hasChildren): ?>
                                <button type="button"
                                        class="submenu-toggle"
                                        aria-expanded="false"
                                        aria-label="<?= $escaper->escapeHtmlAttr(__('Toggle %1 submenu', $title)) ?>">
                                    <span class="toggle-icon" aria-hidden="true">+</span>
                                </button>
                            <?php endif; ?>
                        </a>

                        <?php if ($hasChildren): ?>
                            <ul class="submenu level1" role="menu" style="display: none;">
                                <?php foreach ($children as $childIndex => $child): ?>
                                    <?php
                                    $childIsActive = $getValue($child, 'is_active', 'getIsActive', true);
                                    if (!$childIsActive) {
                                        continue;
                                    }
                                    ?>
                                    <?= /* @noEscape */ $block->getLayout()
                                        ->createBlock(\Panth\MegaMenu\Block\MenuItem::class)
                                        ->setTemplate('Panth_MegaMenu::luma/mobile/item.phtml')
                                        ->setData('item', $child)
                                        ->setData('level', 1)
                                        ->setData('index', $childIndex)
                                        ->toHtml() ?>
                                <?php endforeach; ?>
                            </ul>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        </div>
    </nav>

    <!-- Overlay -->
    <div class="mobile-menu-overlay"
         data-action="close-nav"
         aria-hidden="true"></div>
</div>

<script type="text/javascript">
require([
    'jquery'
], function($) {
    'use strict';

    $(document).ready(function() {
        var $container = $('#<?= $escaper->escapeJs($uniqueId) ?>');
        var $nav = $container.find('.mobile-navigation');
        var $overlay = $container.find('.mobile-menu-overlay');
        var $closeBtn = $container.find('[data-action="close-nav"]');
        var animationSpeed = <?= (int) $animationSpeed ?>;

        /**
         * Open mobile menu
         */
        function openMenu() {
            $nav.addClass('active').attr('aria-hidden', 'false');
            $overlay.addClass('active');
            $('body').addClass('mobile-menu-open');

            // Trap focus within menu
            $nav.find('a, button').first().focus();

            // Prevent body scroll
            $('body').css('overflow', 'hidden');
        }

        /**
         * Close mobile menu
         */
        function closeMenu() {
            $nav.removeClass('active').attr('aria-hidden', 'true');
            $overlay.removeClass('active');
            $('body').removeClass('mobile-menu-open');

            // Collapse all open submenus
            $nav.find('.mobile-nav-item.active').removeClass('active');
            $nav.find('.submenu:visible').slideUp(animationSpeed);
            $nav.find('.submenu-toggle').attr('aria-expanded', 'false');

            // Restore body scroll
            $('body').css('overflow', '');
        }

        // Bind to Magento's default navigation toggle
        $(document).on('click', '.action.nav-toggle, [data-action="toggle-nav"]', function(e) {
            e.preventDefault();
            e.stopPropagation();

            if ($nav.hasClass('active')) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        // Close button click
        $closeBtn.on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            closeMenu();
        });

        // Overlay click
        $overlay.on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            closeMenu();
        });

        // ESC key to close
        $(document).on('keydown', function(e) {
            if (e.keyCode === 27 && $nav.hasClass('active')) {
                closeMenu();
            }
        });

        /**
         * Handle accordion submenu toggles for ALL nested levels
         * This works recursively for unlimited menu depth
         */
        $nav.on('click', '.submenu-toggle', function(e) {
            e.preventDefault();
            e.stopPropagation();

            var $toggle = $(this);
            var $item = $toggle.closest('.mobile-nav-item');
            var $submenu = $item.find('> .submenu');
            var isOpen = $item.hasClass('active');

            if (isOpen) {
                // Close this submenu and all nested submenus
                $submenu.slideUp(animationSpeed, function() {
                    $item.removeClass('active');
                    $toggle.attr('aria-expanded', 'false');
                    $toggle.find('.toggle-icon').text('+');

                    // Close all nested submenus
                    $submenu.find('.mobile-nav-item.active').removeClass('active');
                    $submenu.find('.submenu').hide();
                    $submenu.find('.submenu-toggle').attr('aria-expanded', 'false');
                    $submenu.find('.toggle-icon').text('+');
                });
            } else {
                // Close sibling submenus at the same level
                $item.siblings('.active').each(function() {
                    var $sibling = $(this);
                    var $siblingSubmenu = $sibling.find('> .submenu');
                    $siblingSubmenu.slideUp(animationSpeed, function() {
                        $sibling.removeClass('active');
                        $sibling.find('> .mobile-nav-link .submenu-toggle').attr('aria-expanded', 'false');
                        $sibling.find('> .mobile-nav-link .toggle-icon').text('+');
                    });
                });

                // Open this submenu
                $submenu.slideDown(animationSpeed, function() {
                    $item.addClass('active');
                    $toggle.attr('aria-expanded', 'true');
                    $toggle.find('.toggle-icon').text('−');
                });
            }

            return false;
        });

        /**
         * Prevent navigation on parent items (items with children)
         * Allow normal navigation on leaf items (items without children)
         */
        $nav.on('click', '.mobile-nav-link', function(e) {
            var $link = $(this);
            var $item = $link.closest('.mobile-nav-item');
            var $toggle = $link.find('.submenu-toggle');

            // If item has children, prevent default and toggle submenu
            if ($item.hasClass('has-children') || $item.hasClass('parent')) {
                // If clicking on the toggle button, let it handle the event
                if ($(e.target).closest('.submenu-toggle').length > 0) {
                    return;
                }

                // Otherwise, trigger the toggle button
                e.preventDefault();
                $toggle.trigger('click');
                return false;
            }

            // For leaf items without children, allow normal navigation
            // Menu will close after navigation
        });

        /**
         * Keyboard navigation support
         */
        $nav.on('keydown', '.mobile-nav-link', function(e) {
            var $link = $(this);
            var $item = $link.closest('.mobile-nav-item');

            // Space or Enter on parent items toggles submenu
            if ((e.keyCode === 32 || e.keyCode === 13) && ($item.hasClass('has-children') || $item.hasClass('parent'))) {
                e.preventDefault();
                $link.find('.submenu-toggle').trigger('click');
                return false;
            }
        });
    });
});
</script>

<style type="text/css">
