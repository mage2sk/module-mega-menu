<?php
/**
 * Panth MegaMenu - Simplified Mobile Menu (Luma)
 *
 * Works with Magento's existing mobile toggle button
 * No need to render our own toggle - just the menu panel
 *
 * @var \Panth\MegaMenu\Block\Menu $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Panth\MegaMenu\Block\Menu $block */
$menuTree = $block->getCurrentMenuTree();
$uniqueId = uniqid('panth-mobile-');

// Helper function
$getValue = function($item, $key, $method = null, $default = null) {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    return $method && method_exists($item, $method) ? $item->$method() : $default;
};
?>

<!-- PANTH MOBILE MENU LOADED -->
<div class="panth-mobile-menu-wrapper">
    <nav class="panth-mobile-navigation"
         id="<?= $escaper->escapeHtmlAttr($uniqueId) ?>"
         role="navigation"
         aria-label="<?= $escaper->escapeHtmlAttr(__('Mobile Menu')) ?>"
         aria-hidden="true">

        <!-- Menu Header -->
        <div class="panth-mobile-header">
            <h2 class="panth-mobile-title"><?= $escaper->escapeHtml(__('Menu')) ?></h2>
            <button type="button"
                    class="panth-mobile-close"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Close Menu')) ?>">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>

        <!-- Menu Content -->
        <div class="panth-mobile-content">
            <?php if (!empty($menuTree)): ?>
            <ul class="panth-mobile-list">
                <?php foreach ($menuTree as $item): ?>
                    <?php
                    $isActive = $getValue($item, 'is_active', 'getIsActive', true);
                    if (!$isActive) continue;

                    $title = $escaper->escapeHtml($getValue($item, 'title', 'getTitle', ''));
                    $url = $escaper->escapeUrl($getValue($item, 'url', 'getUrl', '#'));
                    $children = $getValue($item, 'children', 'getChildren', []);
                    $hasChildren = !empty($children);
                    $icon = $getValue($item, 'icon', 'getIconClass', '');
                    ?>
                    <li class="panth-mobile-item <?= $hasChildren ? 'has-children' : '' /* @noEscape */ ?>">
                        <a href="<?= /* @noEscape */ $url ?>" class="panth-mobile-link">
                            <?php if ($icon): ?>
                                <span class="menu-icon <?= $escaper->escapeHtmlAttr($icon) ?>"></span>
                            <?php endif; ?>
                            <span class="menu-text"><?= /* @noEscape */ $title ?></span>
                            <?php if ($hasChildren): ?>
                                <button type="button" class="submenu-toggle" aria-expanded="false">
                                    <span>+</span>
                                </button>
                            <?php endif; ?>
                        </a>

                        <?php if ($hasChildren): ?>
                            <ul class="panth-mobile-submenu" style="display: none;">
                                <?php foreach ($children as $child): ?>
                                    <?php
                                    $childActive = $getValue($child, 'is_active', 'getIsActive', true);
                                    if (!$childActive) continue;

                                    $childTitle = $escaper->escapeHtml($getValue($child, 'title', 'getTitle', ''));
                                    $childUrl = $escaper->escapeUrl($getValue($child, 'url', 'getUrl', '#'));
                                    $childIcon = $getValue($child, 'icon', 'getIconClass', '');
                                    ?>
                                    <li class="panth-mobile-item">
                                        <a href="<?= /* @noEscape */ $childUrl ?>" class="panth-mobile-link">
                                            <?php if ($childIcon): ?>
                                                <span class="menu-icon <?= $escaper->escapeHtmlAttr($childIcon) ?>"></span>
                                            <?php endif; ?>
                                            <span class="menu-text"><?= /* @noEscape */ $childTitle ?></span>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>
            </ul>
            <?php else: ?>
            <p class="panth-mobile-empty"><?= $escaper->escapeHtml(__('No menu items available.')) ?></p>
            <?php endif; ?>
        </div>
    </nav>

    <!-- Overlay -->
    <div class="panth-mobile-overlay" aria-hidden="true"></div>
</div>

<script type="text/javascript">

require(['jquery'], function($) {
    'use strict';


    $(document).ready(function() {

        var $nav = $('.panth-mobile-navigation');
        var $overlay = $('.panth-mobile-overlay');
        var $body = $('body');

            nav: $nav.length,
            overlay: $overlay.length,
            toggleButtons: $('[data-action="toggle-nav"]').length
        });

        // Open menu function
        function openMenu() {
            $nav.addClass('active').attr('aria-hidden', 'false');
            $overlay.addClass('active');
            $body.addClass('panth-menu-open').css('overflow', 'hidden');
        }

        // Close menu function
        function closeMenu() {
            $nav.removeClass('active').attr('aria-hidden', 'true');
            $overlay.removeClass('active');
            $body.removeClass('panth-menu-open').css('overflow', '');
        }

        // Bind to ANY element with data-action="toggle-nav" (Magento's default)
        $(document).on('click', '[data-action="toggle-nav"]', function(e) {
            e.preventDefault();
            e.stopPropagation();

            if ($nav.hasClass('active')) {
                closeMenu();
            } else {
                openMenu();
            }

            return false;
        });

        // Close button
        $('.panth-mobile-close').on('click', function(e) {
            e.preventDefault();
            closeMenu();
        });

        // Overlay click
        $overlay.on('click', function(e) {
            e.preventDefault();
            closeMenu();
        });

        // ESC key
        $(document).on('keydown', function(e) {
            if (e.keyCode === 27 && $nav.hasClass('active')) {
                closeMenu();
            }
        });

        // Submenu toggles
        $(document).on('click', '.panth-mobile-navigation .submenu-toggle', function(e) {
            e.preventDefault();
            e.stopPropagation();

            var $toggle = $(this);
            var $item = $toggle.closest('.panth-mobile-item');
            var $submenu = $item.find('> .panth-mobile-submenu');

            if ($item.hasClass('active')) {
                $submenu.slideUp(200);
                $item.removeClass('active');
                $toggle.attr('aria-expanded', 'false');
                $toggle.find('span').text('+');
            } else {
                $submenu.slideDown(200);
                $item.addClass('active');
                $toggle.attr('aria-expanded', 'true');
                $toggle.find('span').text('-');
            }
        });
    });
});
</script>

