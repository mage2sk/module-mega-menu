}
.pmenu-cms-block img { max-width: 100%; height: auto; border-radius: 6px; }
.pmenu-cms-block h3, .pmenu-cms-block h4 { font-size: 14px; font-weight: 700; margin: 0 0 4px; color: #1f2937; }
.pmenu-cms-block p { font-size: 13px; margin: 0 0 6px; color: #6b7280; }
.pmenu-cms-block a, .pmenu-cms-block a:visited { color: var(--color-primary, #0D9488); font-size: 13px; }
.pmenu-cms-block a:hover { text-decoration: underline; }
.pmenu-mega-footer { border-top: 1px solid #e5e7eb; padding: 12px 24px; }
.pmenu-mega-footer .widget, .pmenu-mega-footer > div { background: #f9fafb; border-radius: 8px; padding: 12px; }
.pmenu-dropdown-image { padding: 0 24px 16px; }
.pmenu-dropdown-image img { max-width: 100%; height: auto; border-radius: 8px; }

/* ══════════ MOBILE HAMBURGER ══════════ */
.pmenu-hamburger-btn {
    display: none; align-items: center; justify-content: center;
    background: none; border: none; padding: 8px;
    cursor: pointer; color: #1f2937;
    min-width: 44px; min-height: 44px;
}
.pmenu-hamburger-icon { display: flex; flex-direction: column; gap: 5px; width: 22px; }
.pmenu-hamburger-icon span { display: block; height: 2px; background: currentColor; border-radius: 1px; transition: transform 0.3s, opacity 0.3s; }
.pmenu-hamburger-btn.is-active .pmenu-hamburger-icon span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.pmenu-hamburger-btn.is-active .pmenu-hamburger-icon span:nth-child(2) { opacity: 0; }
.pmenu-hamburger-btn.is-active .pmenu-hamburger-icon span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* ══════════ MOBILE OVERLAY ══════════ */
.pmenu-mobile-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 300; }
.pmenu-mobile-overlay.is-visible { display: block; }

/* ══════════ MOBILE DRAWER (matches Hyva exactly) ══════════ */
.pmenu-mobile-drawer {
    position: fixed; top: 0; bottom: 0;
    width: 85vw; max-width: 380px;
    background: #fff; z-index: 400;
    overflow-y: auto; -webkit-overflow-scrolling: touch;
    transition: transform 0.3s ease;
    box-shadow: 0 0 30px rgba(0,0,0,0.15);
    font-family: 'DM Sans', 'Inter', system-ui, -apple-system, sans-serif;
}
.pmenu-mobile-drawer--left { left: 0; transform: translateX(-100%); }
.pmenu-mobile-drawer--right { right: 0; transform: translateX(100%); }
.pmenu-mobile-drawer.is-open { transform: translateX(0); }

/* ── Drawer header (matches Hyva: "Menu" + X, white bg, border) ── */
.pmenu-mobile-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e5e7eb;
    position: sticky; top: 0; background: #fff; z-index: 10;
}
.pmenu-mobile-header-title { font-size: 18px; font-weight: 800; color: #1f2937; }
.pmenu-mobile-close {
    background: none; border: none; cursor: pointer;
    color: #6b7280; padding: 4px;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; line-height: 1;
}
.pmenu-mobile-close:hover { color: #1f2937; }

/* ── Mobile list (matches Hyva: clean, border-bottom on each item) ── */
.pmenu-mobile-list { list-style: none; margin: 0; padding: 0; }
.pmenu-mobile-item { list-style: none; border-bottom: 1px solid #f3f4f6; }
.pmenu-mobile-level-0 > .pmenu-mobile-item { border-bottom-color: #e5e7eb; }
.pmenu-mobile-row { display: flex; align-items: center; }

/* ── Mobile links ── */
.pmenu-mobile-link {
    flex: 1; display: flex; align-items: center; gap: 6px;
    padding: 14px 20px;
    color: #1f2937; font-size: 15px;
