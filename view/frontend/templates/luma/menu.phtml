.pmenu-mobile-toggle-sub:hover { color: #374151; }
.pmenu-mobile-children { overflow: hidden; }

/* Active/open state */
.pmenu-mobile-item.is-open > .pmenu-mobile-row > .pmenu-mobile-toggle-sub { color: #374151; }

.pmenu-mobile-image { padding: 4px 20px 8px; }
.pmenu-mobile-image img { max-width: 100%; height: auto; border-radius: 6px; }

/* ── Mobile CMS blocks ── */
