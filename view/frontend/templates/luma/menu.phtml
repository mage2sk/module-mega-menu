<!-- Panth MegaMenu — Vanilla JS (matches Hyva Alpine.js behavior) -->
<script>
function initPanthMegaMenu() {
    'use strict';
    // Prevent double init
    if (window._panthMenuInitialized) return;
    window._panthMenuInitialized = true;

    // ═══════════════════════════════════════════════
    // Replace all CSS triangle arrows with SVG chevrons (matches Hyva)
    // ═══════════════════════════════════════════════
    var svgChevron = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>';
    document.querySelectorAll('.pmenu-link .pmenu-arrow-down').forEach(function(arrow) {
        arrow.innerHTML = svgChevron;
        arrow.style.cssText = 'display:inline-flex;align-items:center;width:16px;height:16px;opacity:0.5;border:none;transition:transform 0.2s;';
    });
    document.querySelectorAll('.pmenu-mobile-toggle-sub .pmenu-arrow-down').forEach(function(arrow) {
        arrow.innerHTML = svgChevron;
        arrow.style.cssText = 'display:inline-flex;align-items:center;width:18px;height:18px;border:none;transition:transform 0.2s;';
    });

    // ═══════════════════════════════════════════════
    // DESKTOP: Hover intent dropdowns
    // ═══════════════════════════════════════════════
    var timers = {};
    var DELAY_OPEN = <?= (int)$hoverDelay ?: 150 ?>;
    var DELAY_CLOSE = 300;

    function closeAllDropdowns() {
        document.querySelectorAll('.pmenu-item.has-children').forEach(function(el) {
            el.classList.remove('is-open');
            var link = el.querySelector(':scope > .pmenu-link');
            if (link) link.setAttribute('aria-expanded', 'false');
        });
    }

    document.querySelectorAll('.pmenu-item.has-children').forEach(function(item) {
        var itemId = item.getAttribute('data-item-id') || Math.random();

        // Hover open
        item.addEventListener('mouseenter', function() {
            if (timers[itemId]) clearTimeout(timers[itemId]);
            timers[itemId] = setTimeout(function() {
                closeAllDropdowns();
                item.classList.add('is-open');
                var link = item.querySelector(':scope > .pmenu-link');
                if (link) link.setAttribute('aria-expanded', 'true');
            }, DELAY_OPEN);
        });

        // Hover close
        item.addEventListener('mouseleave', function() {
            if (timers[itemId]) clearTimeout(timers[itemId]);
            timers[itemId] = setTimeout(function() {
                item.classList.remove('is-open');
                var link = item.querySelector(':scope > .pmenu-link');
                if (link) link.setAttribute('aria-expanded', 'false');
            }, DELAY_CLOSE);
        });

        // Click on link/arrow toggles
        var link = item.querySelector(':scope > .pmenu-link');
        if (link) {
            link.addEventListener('click', function(e) {
                var arrow = e.target.closest('.pmenu-arrow-down');
                if (arrow || (window.innerWidth < 1024 && item.classList.contains('has-children'))) {
                    e.preventDefault();
                    e.stopPropagation();
                    var isOpen = item.classList.contains('is-open');
                    closeAllDropdowns();
                    if (!isOpen) {
                        item.classList.add('is-open');
                        link.setAttribute('aria-expanded', 'true');
                    }
                }
            });
        }
    });

    // Click outside closes desktop dropdowns
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.pmenu-nav')) {
            closeAllDropdowns();
        }
    });

    // Escape closes desktop dropdowns
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeAllDropdowns();
            closeMobileMenu();
        }
    });

    // ═══════════════════════════════════════════════
    // MOBILE: Hamburger + Drawer + Sub-menu toggles
    // ═══════════════════════════════════════════════
    var hamburger = document.querySelector('.pmenu-hamburger-btn');
    var drawer = document.querySelector('.pmenu-mobile-drawer');
    var closeBtn = document.querySelector('.pmenu-mobile-close');

    // Create overlay dynamically
    var overlay = document.createElement('div');
    overlay.className = 'pmenu-mobile-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:399;display:none;';
    document.body.appendChild(overlay);

    function openMobileMenu() {
        if (!drawer) return;
        drawer.classList.add('is-open');
        overlay.style.display = 'block';
        document.body.style.overflow = 'hidden';
        if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
    }

    function closeMobileMenu() {
        if (!drawer) return;
        drawer.classList.remove('is-open');
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
    }

    if (hamburger) hamburger.addEventListener('click', openMobileMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMobileMenu);
    overlay.addEventListener('click', closeMobileMenu);

    // ═══════════════════════════════════════════════
    // DESKTOP: Deep level (Level 3+) toggle buttons
    // Replace CSS triangle with SVG chevron, make it a proper flex row
    // ═══════════════════════════════════════════════
    document.querySelectorAll('.pmenu-deep-toggle').forEach(function(toggle) {
        // Replace inner arrow-down span with SVG
        toggle.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>';

        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var deepItem = toggle.closest('.pmenu-deep-item');
            if (!deepItem) return;
            var children = deepItem.querySelector('.pmenu-deep-children');
            if (!children) return;

            var isOpen = children.style.display !== 'none';
            children.style.display = isOpen ? 'none' : 'block';
            deepItem.classList.toggle('is-open', !isOpen);
            toggle.classList.toggle('is-rotated', !isOpen);
        });
    });

    // ═══════════════════════════════════════════════
    // DESKTOP: Sub-item toggles (Level 2 items with deep children)
    // Wraps link + chevron in a flex row — matches Hyva's Alpine accordion
    // ═══════════════════════════════════════════════
    document.querySelectorAll('.pmenu-sub-item.has-children').forEach(function(subItem) {
        var deepChildren = subItem.querySelector('.pmenu-deep-children');
        if (!deepChildren) return;

        var subLink = subItem.querySelector('.pmenu-sub-link');
        if (!subLink) return;

        // Create a flex wrapper (like Hyva's "flex items-center" div)
        var wrapper = document.createElement('div');
        wrapper.className = 'pmenu-sub-row';
        subLink.parentNode.insertBefore(wrapper, subLink);
        wrapper.appendChild(subLink);

        // Create chevron button
        var chevron = document.createElement('button');
        chevron.className = 'pmenu-sub-chevron';
        chevron.setAttribute('aria-label', 'Toggle submenu');
        chevron.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>';
        wrapper.appendChild(chevron);

        chevron.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var isOpen = deepChildren.style.display !== 'none';
            deepChildren.style.display = isOpen ? 'none' : 'block';
            subItem.classList.toggle('is-open', !isOpen);
            chevron.classList.toggle('is-rotated', !isOpen);
        });
    });

    // ═══════════════════════════════════════════════
    // MOBILE: Sub-menu toggles (accordion)
    // ═══════════════════════════════════════════════
    document.querySelectorAll('.pmenu-mobile-toggle-sub').forEach(function(toggle) {
        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var item = toggle.closest('.pmenu-mobile-item');
            if (!item) return;
            var children = item.querySelector('.pmenu-mobile-children');
            if (!children) return;

            var isOpen = children.style.display !== 'none';
            children.style.display = isOpen ? 'none' : 'block';
            item.classList.toggle('is-open', !isOpen);

            var arrow = toggle.querySelector('.pmenu-arrow-down');
            if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', !isOpen);
        });
    });

    // Active page highlighting
    var path = window.location.pathname;
    document.querySelectorAll('.pmenu-link[href], .pmenu-mobile-drawer a[href]').forEach(function(link) {
        try {
            var linkPath = new URL(link.href).pathname;
            if (linkPath === path) {
                link.classList.add('pmenu-active');
                link.style.color = 'var(--pmenu-active-text, #0D9488)';
                link.style.fontWeight = '700';
            }
        } catch(e) {}
    });

    console.log('[PanthMegaMenu] Initialized: ' +
        document.querySelectorAll('.pmenu-item.has-children').length + ' desktop, ' +
        document.querySelectorAll('.pmenu-mobile-toggle-sub').length + ' mobile toggles');
}

// Initialize on multiple events to ensure it runs after all rendering
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPanthMegaMenu);
} else {
    initPanthMegaMenu();
}
// Also try on window load as fallback
window.addEventListener('load', initPanthMegaMenu);
</script>

