<script>
(function() {
    function initPmenuScroll() {
        var wrap = document.getElementById('pmenuScrollWrap');
        var ul = wrap ? wrap.querySelector('.pmenu-items') : null;
        var btnL = document.getElementById('pmenuScrollLeft');
        var btnR = document.getElementById('pmenuScrollRight');
        var fadeL = document.getElementById('pmenuFadeLeft');
        var fadeR = document.getElementById('pmenuFadeRight');
        if (!ul || !btnL || !btnR) return;

        var offset = 0, animFrame = null, targetOff = 0;
        function getVisibleWidth() { return wrap.clientWidth; }
        function getMaxOffset() { return Math.max(0, ul.scrollWidth - getVisibleWidth()); }
        function update() {
            var maxOff = getMaxOffset();
            var hasOverflow = maxOff > 2;
            btnL.classList.toggle('visible', hasOverflow && offset > 2);
            btnR.classList.toggle('visible', hasOverflow && offset < maxOff - 2);
            if (fadeL) fadeL.classList.toggle('visible', hasOverflow && offset > 2);
            if (fadeR) fadeR.classList.toggle('visible', hasOverflow && offset < maxOff - 2);
        }
        function smoothTo() {
            var diff = targetOff - offset;
            if (Math.abs(diff) < 0.5) { offset = targetOff; animFrame = null; }
            else { offset += diff * 0.2; animFrame = requestAnimationFrame(smoothTo); }
            ul.style.transform = offset > 0 ? 'translateX(-' + offset + 'px)' : '';
            update();
        }
        btnL.addEventListener('click', function() {
            offset = Math.max(0, offset - 200); targetOff = offset;
            ul.style.transform = 'translateX(-' + offset + 'px)'; update();
        });
        btnR.addEventListener('click', function() {
            offset = Math.min(getMaxOffset(), offset + 200); targetOff = offset;
            ul.style.transform = 'translateX(-' + offset + 'px)'; update();
        });
        wrap.addEventListener('wheel', function(e) {
            var maxOff = getMaxOffset();
            if (maxOff <= 2) return;
            e.preventDefault();
            targetOff = Math.max(0, Math.min(maxOff, (animFrame ? targetOff : offset) + (e.deltaY !== 0 ? e.deltaY : e.deltaX) * 0.5));
            if (!animFrame) animFrame = requestAnimationFrame(smoothTo);
        }, { passive: false });
        window.addEventListener('resize', function() {
            var m = getMaxOffset();
            if (offset > m) { offset = m; targetOff = m; ul.style.transform = offset > 0 ? 'translateX(-' + offset + 'px)' : ''; }
            update();
        });
        update();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPmenuScroll);
    } else {
        initPmenuScroll();
    }
})();
</script>

