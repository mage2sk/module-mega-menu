<?php
/**
 * Panth MegaMenu - Complete Luma Frontend Template
 *
 * Desktop: Horizontal nav bar with hover dropdowns (mega panel / simple dropdown)
 * Mobile:  Hamburger button + off-canvas drawer with accordion
 *
 * Uses RequireJS/jQuery and data-mage-init (NO Alpine.js, NO Tailwind).
 * All admin per-item fields fully supported.
 *
 * @var \Panth\MegaMenu\Block\Menu $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isEnabled()) {
    return;
}

$menuTree = $block->getCurrentMenuTree();
$menu     = $block->getCurrentMenu();
$helper   = $block->getMenuHelper();
$renderer = $block->getMenuRenderer();

if (empty($menuTree)) {
    return;
}

// ── Admin config ──
$hoverEffect     = $escaper->escapeHtmlAttr($helper->getHoverEffect() ?: 'underline');
$animationType   = $escaper->escapeHtmlAttr($helper->getAnimationType() ?: 'fade');
$animationDur    = (int) ($helper->getAnimationDuration() ?: 200);
$hoverDelay      = (int) ($helper->getHoverIntentDelay() ?: 150);
$showIcons       = (bool) $helper->showIcons();
$showImages      = (bool) $helper->showImages();
$maxDepth        = (int) ($helper->getMaxDepth() ?: 5);
$columns         = (int) ($helper->getColumns() ?: 4);
$showCount       = (bool) $helper->showCategoryCount();
$enableBlocks    = (bool) $helper->isCustomBlocksEnabled();
$customCss       = $helper->getCustomCss();
$mobilePosition  = $escaper->escapeHtmlAttr($helper->getMobilePosition() ?: 'left');

// ── Menu entity data ──
$menuCssClass  = $menu ? ($menu->getCssClass() ?? '') : '';
$menuCustomCss = $menu ? ($menu->getCustomCss() ?? '') : '';
$menuId        = 'pmenu-' . ($menu ? $menu->getId() : 'default');

// ── Container styling from menu entity ──
$containerStyle = '';
$itemGapStyle   = '';
if ($menu) {
    $bgColor              = $menu->getContainerBgColor();
    $padding              = $menu->getContainerPadding();
    $containerMargin      = $menu->getContainerMargin();
    $gap                  = $menu->getItemGap();
    $maxWidth             = $menu->getContainerMaxWidth();
    $containerBorder      = $menu->getContainerBorder();
    $containerBorderRadius = $menu->getContainerBorderRadius();
    $containerBoxShadow   = $menu->getContainerBoxShadow();

    if ($bgColor)              $containerStyle .= "background-color:{$bgColor};";
    if ($padding)              $containerStyle .= "padding:{$padding};";
    if ($containerMargin)      $containerStyle .= "margin:{$containerMargin};";
    if ($maxWidth)             $containerStyle .= "max-width:{$maxWidth};";
    if ($containerBorder)      $containerStyle .= "border:{$containerBorder};";
    if ($containerBorderRadius) $containerStyle .= "border-radius:{$containerBorderRadius};";
    if ($containerBoxShadow)   $containerStyle .= "box-shadow:{$containerBoxShadow};";

    if ($gap) $itemGapStyle = "gap:{$gap};";
}

// ── Breakpoint / animation config ──
$breakpoint     = (int) $block->getMobileBreakpoint() ?: 1024;
$animationSpeed = (int) $block->getAnimationSpeed() ?: $animationDur;

// ── Desktop widget config (JSON for data-mage-init) ──
$desktopConfig = [
    'hoverDelay'        => $hoverDelay,
    'animationType'     => $animationType,
    'animationDuration' => $animationSpeed,
    'breakpoint'        => $breakpoint,
    'stickyEnabled'     => (bool) $block->isStickyEnabled(),
    'stickyOffset'      => (int) $block->getStickyOffset(),
];

// ── Mobile widget config ──
$mobileConfig = [
    'position'          => $mobilePosition,
    'overlay'           => true,
    'accordion'         => true,
    'breakpoint'        => $breakpoint,
    'animationDuration' => $animationSpeed,
];

// ══════════════════════════════════════════════════════════════════════
// Normalize menu tree items into a common structure
// ══════════════════════════════════════════════════════════════════════
$normalizeItem = function (array $item, int $depth = 0) use (
    &$normalizeItem, $maxDepth, $showIcons, $showImages, $showCount, $enableBlocks
): array {
    $children    = [];
    $rawChildren = $item['children'] ?? [];
    if ($depth < $maxDepth) {
        foreach ($rawChildren as $child) {
            $children[] = $normalizeItem($child, $depth + 1);
        }
        // Sort by sort_order
        usort($children, function ($a, $b) {
            return ((int)$a['sort_order']) - ((int)$b['sort_order']);
        });
    }

    return [
        'title'            => $item['title'] ?? '',
        'url'              => $item['url'] ?? '#',
        'children'         => $children,
        'css_class'        => $item['css_class'] ?? '',
        'icon'             => $showIcons ? ($item['icon'] ?? '') : '',
        'icon_library'     => $item['icon_library'] ?? 'fontawesome',
        'image'            => $showImages ? ($item['image'] ?? '') : '',
        'image_width'      => $item['image_width'] ?? '',
        'image_height'     => $item['image_height'] ?? '',
        'badge_text'       => $item['badge_text'] ?? ($item['badge'] ?? ''),
        'target'           => $item['target'] ?? '_self',
        'rel'              => $item['rel'] ?? '',
        'cms_block'        => $enableBlocks ? ($item['cms_block_id'] ?? ($item['cms_block'] ?? '')) : '',
        'custom_content'   => $item['custom_content'] ?? '',
        'product_count'    => $showCount ? ($item['product_count'] ?? '') : '',
        'display_type'     => $item['display_type'] ?? '',
        'column_width'     => $item['column_width'] ?? '',
        // Styling
        'bg_color'         => $item['bg_color'] ?? '',
        'text_color'       => $item['text_color'] ?? '',
        'font_family'      => $item['font_family'] ?? '',
        'font_size'        => $item['font_size'] ?? '',
        'font_weight'      => $item['font_weight'] ?? '',
        'text_transform'   => $item['text_transform'] ?? '',
        'padding'          => $item['padding'] ?? '',
        'margin'           => $item['margin'] ?? '',
        'border'           => $item['border'] ?? '',
        'border_radius'    => $item['border_radius'] ?? '',
        'box_shadow'       => $item['box_shadow'] ?? '',
        'opacity'          => $item['opacity'] ?? '',
        'hover_effect'     => $item['hover_effect'] ?? '',
        'hover_bg_color'   => $item['hover_bg_color'] ?? '',
        'hover_text_color' => $item['hover_text_color'] ?? '',
        'animation'        => $item['animation'] ?? '',
        // Visibility
        'is_active'        => !isset($item['is_active']) || !empty($item['is_active']),
        'sort_order'       => $item['sort_order'] ?? 0,
        'show_on_desktop'  => !isset($item['show_on_desktop']) || !empty($item['show_on_desktop']),
        'show_on_mobile'   => !isset($item['show_on_mobile']) || !empty($item['show_on_mobile']),
        'start_date'       => $item['start_date'] ?? '',
        'end_date'         => $item['end_date'] ?? '',
    ];
};

// ── Build per-item inline style string ──
$getItemStyle = function (array $item): string {
    $s = [];
    if (!empty($item['bg_color']))       $s[] = 'background-color:' . $item['bg_color'];
    if (!empty($item['text_color']))     $s[] = 'color:' . $item['text_color'];
    if (!empty($item['font_family']))    $s[] = 'font-family:' . $item['font_family'];
    if (!empty($item['font_size']))      $s[] = 'font-size:' . $item['font_size'];
    if (!empty($item['font_weight']))    $s[] = 'font-weight:' . $item['font_weight'];
    if (!empty($item['text_transform'])) $s[] = 'text-transform:' . $item['text_transform'];
    if (!empty($item['padding']))        $s[] = 'padding:' . $item['padding'];
    if (!empty($item['margin']))         $s[] = 'margin:' . $item['margin'];
    if (!empty($item['border']))         $s[] = 'border:' . $item['border'];
    if (!empty($item['border_radius']))  $s[] = 'border-radius:' . $item['border_radius'];
    if (!empty($item['box_shadow']))     $s[] = 'box-shadow:' . $item['box_shadow'];
    if (!empty($item['opacity']))        $s[] = 'opacity:' . $item['opacity'];
    return implode(';', $s);
};

// ── Schedule-based visibility ──
$isItemScheduleActive = function (array $item): bool {
    $now = time();
    if (!empty($item['start_date']) && strtotime($item['start_date']) > $now) return false;
    if (!empty($item['end_date']) && strtotime($item['end_date']) < $now) return false;
    return true;
};

// ── Filter by desktop visibility ──
$filterDesktop = function (array $items) use ($isItemScheduleActive): array {
    return array_values(array_filter($items, function ($i) use ($isItemScheduleActive) {
        return !empty($i['is_active']) && !empty($i['show_on_desktop']) && $isItemScheduleActive($i);
    }));
};

// ── Filter by mobile visibility ──
$filterMobile = function (array $items) use ($isItemScheduleActive): array {
    return array_values(array_filter($items, function ($i) use ($isItemScheduleActive) {
        return !empty($i['is_active']) && !empty($i['show_on_mobile']) && $isItemScheduleActive($i);
    }));
};

// ── Has grandchildren? ──
$hasGrandchildren = function (array $children): bool {
    foreach ($children as $c) {
        if (!empty($c['children'])) return true;
    }
    return false;
};

// ── Normalize all items ──
$items = [];
foreach ($menuTree as $raw) {
    $items[] = $normalizeItem($raw);
}
usort($items, function ($a, $b) {
    return ((int)$a['sort_order']) - ((int)$b['sort_order']);
});

$desktopItems = $filterDesktop($items);
$mobileItems  = $filterMobile($items);

// ══════════════════════════════════════════════════════════════════════
// Recursive renderers (closures)
// ══════════════════════════════════════════════════════════════════════

/**
 * Render Level 3+ items recursively inside a mega column
 */
$renderDeepItems = function (array $items, int $level, string $parentKey) use (
    &$renderDeepItems, $escaper, $maxDepth, $getItemStyle, $filterDesktop, $renderer, $enableBlocks
) {
    if ($level > $maxDepth) return;
    $items = $filterDesktop($items);
    if (empty($items)) return;
    ?>
    <ul class="pmenu-deep-list pmenu-deep-level-<?= (int) $level ?>">
        <?php foreach ($items as $di => $deep):
            $hasKids   = !empty($deep['children']);
            $deepKey   = $parentKey . '_d' . $level . '_' . $di;
            $deepStyle = $getItemStyle($deep);
        ?>
        <li class="pmenu-deep-item<?= $hasKids ? ' has-children' : '' ?><?= !empty($deep['css_class']) ? ' ' . $escaper->escapeHtmlAttr($deep['css_class']) : '' ?>">
            <div class="pmenu-deep-row">
                <a href="<?= $escaper->escapeUrl($deep['url']) ?>"
                   class="pmenu-deep-link"
                   <?php if ($deepStyle): ?>style="<?= $escaper->escapeHtmlAttr($deepStyle) ?>"<?php endif; ?>
                   <?php if (!empty($deep['target']) && $deep['target'] !== '_self'): ?>target="<?= $escaper->escapeHtmlAttr($deep['target']) ?>"<?php endif; ?>
                   <?php if (!empty($deep['rel'])): ?>rel="<?= $escaper->escapeHtmlAttr($deep['rel']) ?>"<?php endif; ?>>
                    <?php if (!empty($deep['icon'])): ?>
                        <?= /* @noEscape */ $renderer->renderIcon($deep['icon'], $deep['icon_library'] ?? 'fontawesome') ?>
                    <?php endif; ?>
                    <?= $escaper->escapeHtml($deep['title']) ?>
                    <?php if (!empty($deep['badge_text'])): ?>
                        <span class="pmenu-badge"><?= $escaper->escapeHtml($deep['badge_text']) ?></span>
                    <?php endif; ?>
                </a>
                <?php if ($hasKids): ?>
                    <button class="pmenu-deep-toggle" data-toggle-key="<?= $escaper->escapeHtmlAttr($deepKey) ?>"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Toggle submenu')) ?>">
                        <span class="pmenu-arrow-down"></span>
                    </button>
                <?php endif; ?>
            </div>
            <?php if (!empty($deep['custom_content'])): ?>
                <div class="pmenu-custom-content"><?= /* @noEscape */ $deep['custom_content'] ?></div>
            <?php endif; ?>
            <?php if ($enableBlocks && !empty($deep['cms_block'])): ?>
                <div class="pmenu-cms-block"><?= /* @noEscape */ $renderer->renderCmsBlock($deep['cms_block']) ?></div>
            <?php endif; ?>
            <?php if ($hasKids): ?>
                <div class="pmenu-deep-children" data-children-key="<?= $escaper->escapeHtmlAttr($deepKey) ?>" style="display:none;">
                    <?php $renderDeepItems($deep['children'], $level + 1, $deepKey); ?>
                </div>
            <?php endif; ?>
        </li>
        <?php endforeach; ?>
    </ul>
    <?php
};

/**
 * Render mega panel (multi-column grid for items with grandchildren)
 */
$renderMegaPanel = function (array $children, string $parentKey) use (
    $escaper, $columns, $renderer, $renderDeepItems, $maxDepth,
    $getItemStyle, $filterDesktop, $showCount, $enableBlocks
) {
    $children   = $filterDesktop($children);
    $actualCols = min(count($children), $columns);
    ?>
    <div class="pmenu-grid cols-<?= (int) $actualCols ?>">
        <?php foreach ($children as $ci => $child):
            $childKey   = $parentKey . '_c' . $ci;
            $childStyle = $getItemStyle($child);
            $childCss   = !empty($child['css_class']) ? ' ' . $escaper->escapeHtmlAttr($child['css_class']) : '';
            $colWidth   = !empty($child['column_width']) ? 'width:' . $escaper->escapeHtmlAttr($child['column_width']) . ';' : '';
        ?>
        <div class="pmenu-column<?= /* @noEscape */ $childCss ?>"<?php if ($colWidth): ?> style="<?= /* @noEscape */ $colWidth ?>"<?php endif; ?>>
            <!-- Column header (Level 1) -->
            <h3 class="pmenu-col-header">
                <a href="<?= $escaper->escapeUrl($child['url']) ?>"
                   <?php if ($childStyle): ?>style="<?= $escaper->escapeHtmlAttr($childStyle) ?>"<?php endif; ?>
                   <?php if (!empty($child['target']) && $child['target'] !== '_self'): ?>target="<?= $escaper->escapeHtmlAttr($child['target']) ?>"<?php endif; ?>
                   <?php if (!empty($child['rel'])): ?>rel="<?= $escaper->escapeHtmlAttr($child['rel']) ?>"<?php endif; ?>>
                    <?php if (!empty($child['icon'])): ?>
                        <?= /* @noEscape */ $renderer->renderIcon($child['icon'], $child['icon_library'] ?? 'fontawesome') ?>
                    <?php endif; ?>
                    <?= $escaper->escapeHtml($child['title']) ?>
                    <?php if ($showCount && !empty($child['product_count'])): ?>
                        <span class="pmenu-count">(<?= $escaper->escapeHtml((string) $child['product_count']) ?>)</span>
                    <?php endif; ?>
                    <?php if (!empty($child['badge_text'])): ?>
                        <span class="pmenu-badge"><?= $escaper->escapeHtml($child['badge_text']) ?></span>
                    <?php endif; ?>
                </a>
            </h3>

            <?php if (!empty($child['image'])): ?>
                <div class="pmenu-col-image">
                    <?= /* @noEscape */ $renderer->renderImage($child, 'medium') ?>
                </div>
            <?php endif; ?>

            <?php if (!empty($child['custom_content'])): ?>
                <div class="pmenu-custom-content"><?= /* @noEscape */ $child['custom_content'] ?></div>
            <?php endif; ?>

            <?php // Level 2 items ?>
            <?php if (!empty($child['children'])):
                $filteredL2 = $filterDesktop($child['children']);
            ?>
            <ul class="pmenu-sub-list">
                <?php foreach ($filteredL2 as $gi => $gc):
                    $gcKey   = $childKey . '_g' . $gi;
                    $gcStyle = $getItemStyle($gc);
                    $gcCss   = !empty($gc['css_class']) ? ' ' . $escaper->escapeHtmlAttr($gc['css_class']) : '';
                    $hasDeep = !empty($gc['children']);
                ?>
                <li class="pmenu-sub-item<?= $hasDeep ? ' has-children' : '' /* @noEscape */ ?><?= /* @noEscape */ $gcCss ?>">
                    <a href="<?= $escaper->escapeUrl($gc['url']) ?>"
                       class="pmenu-sub-link"
                       <?php if ($gcStyle): ?>style="<?= $escaper->escapeHtmlAttr($gcStyle) ?>"<?php endif; ?>
                       <?php if (!empty($gc['target']) && $gc['target'] !== '_self'): ?>target="<?= $escaper->escapeHtmlAttr($gc['target']) ?>"<?php endif; ?>
                       <?php if (!empty($gc['rel'])): ?>rel="<?= $escaper->escapeHtmlAttr($gc['rel']) ?>"<?php endif; ?>>
                        <?php if (!empty($gc['icon'])): ?>
                            <?= /* @noEscape */ $renderer->renderIcon($gc['icon'], $gc['icon_library'] ?? 'fontawesome') ?>
                        <?php endif; ?>
                        <?= $escaper->escapeHtml($gc['title']) ?>
                        <?php if ($showCount && !empty($gc['product_count'])): ?>
                            <span class="pmenu-count">(<?= $escaper->escapeHtml((string) $gc['product_count']) ?>)</span>
                        <?php endif; ?>
                        <?php if (!empty($gc['badge_text'])): ?>
                            <span class="pmenu-badge"><?= $escaper->escapeHtml($gc['badge_text']) ?></span>
                        <?php endif; ?>
                    </a>
                    <?php if (!empty($gc['custom_content'])): ?>
                        <div class="pmenu-custom-content"><?= /* @noEscape */ $gc['custom_content'] ?></div>
                    <?php endif; ?>
                    <?php if ($hasDeep && $maxDepth > 2): ?>
                        <div class="pmenu-deep-children" data-children-key="<?= $escaper->escapeHtmlAttr($gcKey) ?>" style="display:none;">
                            <?php $renderDeepItems($gc['children'], 3, $gcKey); ?>
                        </div>
                    <?php endif; ?>
                </li>
                <?php endforeach; ?>
            </ul>
            <?php endif; ?>

            <?php if ($enableBlocks && !empty($child['cms_block'])): ?>
                <div class="pmenu-cms-block"><?= /* @noEscape */ $renderer->renderCmsBlock($child['cms_block']) ?></div>
            <?php endif; ?>
        </div>
        <?php endforeach; ?>
    </div>
    <?php
};

/**
 * Render simple dropdown (for items without grandchildren)
 */
$renderSimpleDropdown = function (array $children) use (
    $escaper, $renderer, $getItemStyle, $filterDesktop, $showCount, $enableBlocks
) {
    $children = $filterDesktop($children);
    ?>
    <ul class="pmenu-simple-list">
        <?php foreach ($children as $child):
            $sdStyle = $getItemStyle($child);
            $sdCss   = !empty($child['css_class']) ? ' ' . $escaper->escapeHtmlAttr($child['css_class']) : '';
        ?>
        <li class="pmenu-simple-item<?= /* @noEscape */ $sdCss ?>">
            <a href="<?= $escaper->escapeUrl($child['url']) ?>"
               class="pmenu-simple-link"
               <?php if ($sdStyle): ?>style="<?= $escaper->escapeHtmlAttr($sdStyle) ?>"<?php endif; ?>
               <?php if (!empty($child['target']) && $child['target'] !== '_self'): ?>target="<?= $escaper->escapeHtmlAttr($child['target']) ?>"<?php endif; ?>
               <?php if (!empty($child['rel'])): ?>rel="<?= $escaper->escapeHtmlAttr($child['rel']) ?>"<?php endif; ?>>
                <?php if (!empty($child['icon'])): ?>
                    <?= /* @noEscape */ $renderer->renderIcon($child['icon'], $child['icon_library'] ?? 'fontawesome') ?>
                <?php endif; ?>
                <?= $escaper->escapeHtml($child['title']) ?>
                <?php if ($showCount && !empty($child['product_count'])): ?>
                    <span class="pmenu-count">(<?= $escaper->escapeHtml((string) $child['product_count']) ?>)</span>
                <?php endif; ?>
                <?php if (!empty($child['badge_text'])): ?>
                    <span class="pmenu-badge"><?= $escaper->escapeHtml($child['badge_text']) ?></span>
                <?php endif; ?>
            </a>
            <?php if (!empty($child['custom_content'])): ?>
                <div class="pmenu-custom-content"><?= /* @noEscape */ $child['custom_content'] ?></div>
            <?php endif; ?>
            <?php if ($enableBlocks && !empty($child['cms_block'])): ?>
                <div class="pmenu-cms-block"><?= /* @noEscape */ $renderer->renderCmsBlock($child['cms_block']) ?></div>
            <?php endif; ?>
        </li>
        <?php endforeach; ?>
    </ul>
    <?php
};

/**
 * Render mobile accordion items recursively
 */
$renderMobileItems = function (array $items, int $level = 0) use (
    &$renderMobileItems, $escaper, $maxDepth, $renderer,
    $getItemStyle, $filterMobile, $showCount, $enableBlocks
) {
    if ($level > $maxDepth) return;
    $items = $filterMobile($items);
    if (empty($items)) return;
    ?>
    <ul class="pmenu-mobile-list pmenu-mobile-level-<?= (int) $level ?>">
        <?php foreach ($items as $i => $item):
            $hasChildren = !empty($item['children']);
            $mKey        = 'ml' . $level . 'i' . $i;
            $mobStyle    = $getItemStyle($item);
            $mobCss      = !empty($item['css_class']) ? ' ' . $escaper->escapeHtmlAttr($item['css_class']) : '';
        ?>
        <li class="pmenu-mobile-item<?= $hasChildren ? ' has-children' : '' /* @noEscape */ ?><?= /* @noEscape */ $mobCss ?>"
            data-level="<?= (int) $level ?>">
            <div class="pmenu-mobile-row">
                <a href="<?= $escaper->escapeUrl($item['url']) ?>"
                   class="pmenu-mobile-link"
                   <?php if ($mobStyle): ?>style="<?= $escaper->escapeHtmlAttr($mobStyle) ?>"<?php endif; ?>
                   <?php if (!empty($item['target']) && $item['target'] !== '_self'): ?>target="<?= $escaper->escapeHtmlAttr($item['target']) ?>"<?php endif; ?>
                   <?php if (!empty($item['rel'])): ?>rel="<?= $escaper->escapeHtmlAttr($item['rel']) ?>"<?php endif; ?>>
                    <?php if (!empty($item['icon'])): ?>
                        <?= /* @noEscape */ $renderer->renderIcon($item['icon'], $item['icon_library'] ?? 'fontawesome') ?>
                    <?php endif; ?>
                    <span class="pmenu-mobile-title-text"><?= $escaper->escapeHtml($item['title']) ?></span>
                    <?php if ($showCount && !empty($item['product_count'])): ?>
                        <span class="pmenu-count">(<?= $escaper->escapeHtml((string) $item['product_count']) ?>)</span>
                    <?php endif; ?>
                    <?php if (!empty($item['badge_text'])): ?>
                        <span class="pmenu-badge"><?= $escaper->escapeHtml($item['badge_text']) ?></span>
                    <?php endif; ?>
                </a>
                <?php if ($hasChildren): ?>
                    <button class="pmenu-mobile-toggle-sub"
                            data-accordion-key="<?= $escaper->escapeHtmlAttr($mKey) ?>"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Toggle %1', $item['title'])) ?>"
                            aria-expanded="false">
                        <span class="pmenu-arrow-down"></span>
                    </button>
                <?php endif; ?>
            </div>

            <?php if (!empty($item['custom_content'])): ?>
                <div class="pmenu-custom-content"><?= /* @noEscape */ $item['custom_content'] ?></div>
            <?php endif; ?>

            <?php if ($enableBlocks && !empty($item['cms_block'])): ?>
                <div class="pmenu-cms-block"><?= /* @noEscape */ $renderer->renderCmsBlock($item['cms_block']) ?></div>
            <?php endif; ?>

            <?php if (!empty($item['image'])): ?>
                <div class="pmenu-mobile-image">
                    <?= /* @noEscape */ $renderer->renderImage($item, 'small') ?>
                </div>
            <?php endif; ?>

            <?php if ($hasChildren): ?>
                <div class="pmenu-mobile-children" data-accordion-children="<?= $escaper->escapeHtmlAttr($mKey) ?>" style="display:none;">
                    <?php $renderMobileItems($item['children'], $level + 1); ?>
                </div>
            <?php endif; ?>
        </li>
        <?php endforeach; ?>
    </ul>
    <?php
};
?>

<!-- ══════════════ STYLES — matches Hyva Panth MegaMenu exactly ══════════════ -->
<style>
:root {
    --pmenu-animation-speed: <?= (int) $animationSpeed ?>ms;
    --pmenu-breakpoint: <?= (int) $breakpoint ?>px;
}

/* ══════════ RESET — kill Luma's global a colors inside our menu ══════════ */
.pmenu-nav a, .pmenu-nav a:visited, .pmenu-nav a:active,
.pmenu-mobile-drawer a, .pmenu-mobile-drawer a:visited, .pmenu-mobile-drawer a:active {
    color: inherit;
    text-decoration: none;
}

/* ══════════ DESKTOP NAV ══════════ */
.pmenu-nav {
    position: relative;
    z-index: 9999;
    font-family: 'DM Sans', 'Inter', system-ui, -apple-system, sans-serif;
}
.pmenu-bar { position: relative; }
.pmenu-items {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; align-items: center;
}
.pmenu-item { position: relative; list-style: none; }
.pmenu-item.is-mega { position: static; }
.pmenu-item.is-open { z-index: 10000; }

/* ── Level 0 links (matches Hyva: text-sm font-medium, py-4 px-3, gap-1.5) ── */
.pmenu-link {
    display: flex; align-items: center; gap: 6px;
    padding: 16px 12px;
    font-size: 14px; font-weight: 500;
    color: #374151;
    white-space: nowrap;
    transition: color 0.2s;
}
.pmenu-link:hover,
.pmenu-item:hover > .pmenu-link,
.pmenu-item.is-open > .pmenu-link {
    color: var(--color-primary, #0D9488);
}

/* ── Arrow: replaced by SVG via JS, this is just a container ── */
.pmenu-arrow-down {
    display: inline-flex; align-items: center; justify-content: center;
    width: 16px; height: 16px;
    transition: transform 0.2s;
    border: none; background: none;
}
.pmenu-item.is-open > .pmenu-link .pmenu-arrow-down {
    transform: rotate(180deg);
}

/* ── Badge (matches Hyva: 10px, bold, rounded, bg-red-500) ── */
.pmenu-badge {
    display: inline-block; margin-left: 6px;
    padding: 2px 8px; font-size: 10px; font-weight: 700;
    line-height: 1.4; color: #fff; background: #EF4444;
    border-radius: 4px; vertical-align: middle;
    white-space: nowrap; text-transform: uppercase;
}
.pmenu-count {
    font-size: 11px; font-weight: 400; opacity: 0.5; margin-left: 3px;
}

/* ── Hover effects ── */
.pmenu-hover-underline .pmenu-item:hover > .pmenu-link { text-decoration: underline; text-underline-offset: 6px; text-decoration-thickness: 2px; text-decoration-color: var(--color-primary, #0D9488); }
.pmenu-hover-fade .pmenu-item:hover > .pmenu-link { opacity: 0.7; }
.pmenu-hover-highlight .pmenu-item:hover > .pmenu-link { background: #F0FDFA; border-radius: 6px; }
.pmenu-hover-slide .pmenu-item:hover > .pmenu-link { transform: translateY(-2px); }
.pmenu-hover-glow .pmenu-item:hover > .pmenu-link { text-shadow: 0 0 8px currentColor; }
.pmenu-hover-grow .pmenu-item:hover > .pmenu-link { transform: scale(1.05); }

/* ══════════ DROPDOWNS ══════════ */
.pmenu-dropdown {
    position: absolute; top: 100%; z-index: 10001;
    display: none;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 20px 60px -12px rgba(0,0,0,0.15);
    min-width: 220px; margin: 2px 0 0;
    padding: 0; /* Reset megamenu-all.less padding — grid handles its own padding */
    overflow: hidden; /* Clip card corners to dropdown border-radius */
}
.pmenu-dropdown.pmenu-mega { left: 0; right: 0; width: auto; }
.pmenu-dropdown.pmenu-simple { left: 0; width: max-content; max-width: 320px; background: #fff; padding: 0; }
.pmenu-item.is-open > .pmenu-dropdown { display: block; }

/* Animation */
.pmenu-nav[data-anim="fade"] .pmenu-dropdown { opacity: 0; transition: opacity var(--pmenu-animation-speed) ease; }
.pmenu-nav[data-anim="fade"] .pmenu-item.is-open > .pmenu-dropdown { opacity: 1; }
.pmenu-nav[data-anim="slide"] .pmenu-dropdown { opacity: 0; transform: translateY(-6px); transition: opacity var(--pmenu-animation-speed) ease, transform var(--pmenu-animation-speed) ease; }
.pmenu-nav[data-anim="slide"] .pmenu-item.is-open > .pmenu-dropdown { opacity: 1; transform: translateY(0); }
.pmenu-nav[data-anim="grow"] .pmenu-dropdown { opacity: 0; transform: scaleY(0.96); transform-origin: top center; transition: opacity var(--pmenu-animation-speed) ease, transform var(--pmenu-animation-speed) ease; }
.pmenu-nav[data-anim="grow"] .pmenu-item.is-open > .pmenu-dropdown { opacity: 1; transform: scaleY(1); }
.pmenu-nav[data-anim="fade"] .pmenu-dropdown,
.pmenu-nav[data-anim="slide"] .pmenu-dropdown,
.pmenu-nav[data-anim="grow"] .pmenu-dropdown { display: block; visibility: hidden; pointer-events: none; }
.pmenu-nav[data-anim="fade"] .pmenu-item.is-open > .pmenu-dropdown,
.pmenu-nav[data-anim="slide"] .pmenu-item.is-open > .pmenu-dropdown,
.pmenu-nav[data-anim="grow"] .pmenu-item.is-open > .pmenu-dropdown { visibility: visible; pointer-events: auto; }

/* ══════════ MEGA PANEL — Tight gray bg, white card columns (matches Hyva p-6 gap-4) ══════════ */
.pmenu-grid {
    display: grid; gap: 12px; padding: 12px;
}
.pmenu-grid.cols-1 { grid-template-columns: 1fr; }
.pmenu-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
.pmenu-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
.pmenu-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
.pmenu-grid.cols-5 { grid-template-columns: repeat(5, 1fr); }
.pmenu-grid.cols-6 { grid-template-columns: repeat(6, 1fr); }

/* Each column = white card (matches Hyva bg-white rounded-lg p-4 border border-gray-100) */
.pmenu-column {
    min-width: 0;
    background: #fff;
    border-radius: 8px;
    padding: 16px;
    border: 1px solid #f3f4f6;
}

/* ── Column header: teal left-border accent (matches Hyva .panth-col-header) ── */
.pmenu-col-header {
    margin: 0 0 12px; padding: 0 0 0 12px;
    border-bottom: none;
    border-left: 3px solid var(--color-primary, #0D9488);
    font-size: 14px; font-weight: 700;
    color: var(--color-primary, #0D9488); line-height: 1.4;
    text-transform: none; letter-spacing: 0;
}
.pmenu-col-header a { color: inherit; }
.pmenu-col-header a:hover { opacity: 0.8; }
.pmenu-col-image { margin-bottom: 8px; }
.pmenu-col-image img { max-width: 100%; height: auto; border-radius: 6px; }

/* ── Sub list (Level 2 items in mega panel) ── */
.pmenu-sub-list { list-style: none; margin: 0; padding: 0; }
.pmenu-sub-item { list-style: none; }

/* Sub-item flex row (created by JS for items with children) */
.pmenu-sub-row {
    display: flex; align-items: center;
}
.pmenu-sub-row .pmenu-sub-link {
    flex: 1; min-width: 0;
}

.pmenu-sub-link {
    display: block;
    padding: 6px 8px; border-radius: 6px;
    font-size: 14px; color: #374151;
    transition: color 0.15s, background 0.15s;
    line-height: 1.5;
}
.pmenu-sub-link:hover { color: var(--color-primary, #0D9488); background: #f3f4f6; }

/* Sub-item chevron button (matches Hyva's inline toggle) */
.pmenu-sub-chevron {
    flex-shrink: 0;
    background: none; border: none;
    padding: 4px; cursor: pointer;
    color: #9ca3af; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s, transform 0.2s;
}
.pmenu-sub-chevron:hover { color: #374151; }
.pmenu-sub-chevron.is-rotated { transform: rotate(180deg); }
.pmenu-sub-chevron svg { width: 16px; height: 16px; }

.pmenu-sub-item.has-children { position: relative; }
.pmenu-sub-item.is-open > .pmenu-deep-children { display: block !important; }

/* ── Deep items (Level 3+) — indented under parent, matching Hyva (ml-4 = 16px) ── */
.pmenu-deep-list {
    list-style: none; margin: 2px 0 0; padding: 0 0 0 12px;
    border-left: none;
}
.pmenu-deep-row { display: flex; align-items: center; }
.pmenu-deep-link {
    flex: 1; display: block;
    padding: 5px 8px; border-radius: 6px;
    font-size: 14px; color: #4b5563;
    transition: color 0.15s, background 0.15s; line-height: 1.5;
}
.pmenu-deep-link:hover { color: var(--color-primary, #0D9488); background: #f3f4f6; }

/* Deep toggle chevron (matches Hyva's SVG button) */
.pmenu-deep-toggle {
    flex-shrink: 0;
    background: none; border: none;
    padding: 4px; cursor: pointer;
    color: #9ca3af; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s, transform 0.2s;
}
.pmenu-deep-toggle:hover { color: #374151; }
.pmenu-deep-toggle.is-rotated { transform: rotate(180deg); }
.pmenu-deep-toggle svg { width: 14px; height: 14px; }

.pmenu-deep-children { overflow: hidden; }
.pmenu-deep-item.is-open > .pmenu-deep-children { display: block !important; }

/* ── Simple dropdown ── */
.pmenu-simple-list { list-style: none; margin: 0; padding: 8px 0; }
.pmenu-simple-item { list-style: none; }
.pmenu-simple-link {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 20px; font-size: 14px; color: #374151;
    white-space: nowrap; transition: color 0.15s, background 0.15s;
}
.pmenu-simple-link:hover { color: var(--color-primary, #0D9488); background: #f0fdfa; }

/* ── CMS blocks & custom content ── */
.pmenu-custom-content { padding: 4px 0; font-size: 13px; line-height: 1.5; }
.pmenu-cms-block { padding: 8px 0; font-size: 13px; line-height: 1.5; }
.pmenu-cms-block > div, .pmenu-cms-block .widget {
