}
.pmenu-mobile-link:hover { color: var(--color-primary, #0D9488); }

/* Level 0: bold, 16px (matches Hyva) */
.pmenu-mobile-level-0 > .pmenu-mobile-item > .pmenu-mobile-row > .pmenu-mobile-link {
    font-size: 16px; font-weight: 700; color: #111827; padding: 16px 20px;
}
/* Level 1: 15px, medium */
.pmenu-mobile-level-1 .pmenu-mobile-link {
    padding-left: 32px; font-size: 15px; font-weight: 500; color: #374151;
}
/* Level 2: 14px, normal */
.pmenu-mobile-level-2 .pmenu-mobile-link {
    padding-left: 48px; font-size: 14px; font-weight: 400; color: #4b5563;
}
/* Level 3: 14px, normal, deeper indent */
.pmenu-mobile-level-3 .pmenu-mobile-link {
    padding-left: 64px; font-size: 14px; font-weight: 400; color: #6b7280;
}
/* Level 4+: */
.pmenu-mobile-level-4 .pmenu-mobile-link {
    padding-left: 80px; font-size: 13px; color: #9ca3af;
}

.pmenu-mobile-title-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── Mobile toggle (SVG chevron, no left border — matches Hyva) ── */
.pmenu-mobile-toggle-sub {
